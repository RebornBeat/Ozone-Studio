    pub end: f32,
}

impl TimeRange {
    pub fn duration(&self) -> f32 {
        self.end - self.start
    }

    pub fn overlaps(&self, other: &TimeRange) -> bool {
        self.start < other.end && self.end > other.start
    }

    pub fn contains(&self, time: f32) -> bool {
        time >= self.start && time <= self.end
    }
}

