fn info(
    id: PipelineID,
    name: &str,
    folder: &str,
    category: &'static str,
    has_ui: bool,
    is_tab: bool,
    desc: &str,
) -> PipelineInfo {
    PipelineInfo {
        id,
        name: name.to_string(),
        folder_name: folder.to_string(),
        category,
        has_ui,
        is_tab,
        description: desc.to_string(),
    }
}

