        #[serde(default)]
        diarize: bool,
        #[serde(default)]
        detect_music: bool,
        #[serde(default)]
        detect_events: bool,
    },

    /// Transcribe audio to text
    Transcribe {
        audio_data: AudioData,
        #[serde(default)]
        language: Option<String>,
        #[serde(default)]
        word_timestamps: bool,
        #[serde(default)]
        speaker_labels: bool,
    },

    /// Perform speaker diarization
    Diarize {
        audio_data: AudioData,
        #[serde(default)]
        num_speakers: Option<u32>,
        #[serde(default)]
        min_speakers: Option<u32>,
        #[serde(default)]
