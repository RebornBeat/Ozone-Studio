        rule_applied: "input".to_string(),
    });

    // If it's a simple number, parse it
    if let Ok(num) = expression.trim().parse::<f64>() {
        result_value = num;
    }

    Ok(EvaluationResult {
        value: MathValue::Real(result_value),
        exact: true,
        precision: Some(15),
        intermediate_steps: steps,
    })
}

