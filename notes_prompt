import bpy, bmesh, numpy as np, json, os
def dump_mesh(mesh, path):
    os.makedirs(path, exist_ok=True)
    bm = bmesh.new(); bm.from_mesh(mesh)
    verts = np.empty((len(mesh.vertices), 3), dtype=np.float32)
    mesh.vertices.foreach_get("co", verts.ravel())
    np.save(os.path.join(path, "verts.npy"), verts)
    faces = np.array([f.vertices for f in mesh.polygons], dtype=np.int32)
    np.save(os.path.join(path, "faces.npy"), faces)
    # All custom attributes
    attrs = {}
    for attr in mesh.attributes:
        data = np.empty(len(mesh.vertices) * attr.data_type_size, dtype=np.float32 if "float" in attr.data_type else np.int32)
        attr.data.foreach_get("value", data)
        attrs[attr.name] = {"type": attr.data_type, "data": data.tolist()}
    with open(os.path.join(path, "attributes.json"), "w") as f: json.dump(attrs, f)
    # ID props, vertex groups, etc.
    json.dump({k: v for k, v in mesh.items()}, open(os.path.join(path, "id_props.json"), "w"))
    bm.free()
