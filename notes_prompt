// PIPELINE METADATA
// ============================================================================

pub const PIPELINE_ID: u64 = 104;
pub const PIPELINE_NAME: &str = "video_analysis";
pub const PIPELINE_VERSION: &str = "0.4.0";
pub const MODALITY: &str = "video";

