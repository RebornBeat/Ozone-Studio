        match &self.model {
            Some(model) if model.is_confident(query) => {
                let suggestions = model.predict_paths(query);
                suggestions.filter(|s| s.confidence >= self.confidence_threshold)
            }
            _ => vec![]  // No suggestions, use traditional
        }
    }
