AMT is built after initial graphs exist. Layer-by-layer — each layer validated independently with 5x consecutive stable loop. No single `build_amt_until_stable` wrapper.

```rust
async fn build_amt_layer_by_layer(&self, state: &mut OrchestrationState) -> OzoneResult<()> {
    let mut current_layer = 0;
    loop {
        current_layer += 1;
        let layer_input = self.gather_layer_input(state, current_layer).await?;
        self.build_amt_layer(state, current_layer, &layer_input).await?;

        // Per-layer: 5x consecutive stable validation
        let mut layer_stable_count = 0;
        let mut layer_round = 0;
        loop {
            layer_round += 1;
            let new_findings = self.validate_amt_layer(state, current_layer).await?;
            let method_gaps = self.cross_reference_methodologies_for_layer(state, current_layer).await?;
            let has_new = !new_findings.is_empty() || !method_gaps.is_empty();

            if has_new {
                layer_stable_count = 0;
                self.expand_amt_layer(state, current_layer, new_findings, method_gaps).await?;
            } else {
                layer_stable_count += 1;
                if layer_stable_count >= 5 { break; }
            }
            if layer_round > 50 { break; }
        }

        if !self.amt_has_pending_sub_intents(state, current_layer).await? { break; }
    }
    state.amt_stable = true;
    Ok(())
}
