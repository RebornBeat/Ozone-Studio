```javascript
module.exports = {
  meta: { title: 'Context', icon: '◈', version: '1.0.0' },

  render: function(container, props, React, ReactDOM) {
    const { useState, useEffect, useCallback, useRef } = React;
    const { executePipeline, getSharedState } = props;

    const MODALITY_COLORS = {
      text: '#2ecc71', code: '#3498db', image: '#e67e22', audio: '#9b59b6',
      video: '#e74c3c', math: '#f1c40f', chemistry: '#1abc9c', dna: '#27ae60',
      eeg: '#8e44ad', '3d': '#ecf0f1', geospatial: '#16a085',
      parametric_cad: '#d35400', kinematics: '#2980b9', bci: '#6c3483',
      radar: '#c0392b', sonar: '#1a5276', hyperspectral: '#7d3c98',
      default: '#95a5a6',
    };

    function edgeStyle(edgeType) {
      if (['Contains','ParentOf','ChildOf','PartOf','HasPart'].includes(edgeType))
        return { stroke: '#666', strokeWidth: 2, strokeDasharray: 'none' };
      if (['Performs','Affects','CausedBy','Enables','Prevents'].includes(edgeType))
        return { stroke: '#e74c3c', strokeWidth: 1.5, strokeDasharray: '5,3' };
      if (['Implies','LogicallyImplies','Supports','SimilarTo'].includes(edgeType))
        return { stroke: '#3498db', strokeWidth: 1.5, strokeDasharray: '8,3' };
      if (['ReferencesModality','ReferencedBy','DescribedBy','Describes',
           'ImplementedIn','Implements','VisualizedAs','Visualizes',
           'SyncedTo','SyncedBy'].includes(edgeType))
        return { stroke: '#f1c40f', strokeWidth: 2.5, strokeDasharray: 'none' };
      if (['DerivedFrom','VersionOf','RefinesTo','ForkedFrom'].includes(edgeType))
        return { stroke: '#9b59b6', strokeWidth: 1, strokeDasharray: '3,3' };
      return { stroke: '#555', strokeWidth: 1, strokeDasharray: 'none' };
    }

    function GraphCanvas({ nodes, edges, selectedNodeId, onNodeSelect, modality }) {
      const svgRef = useRef(null);
      const [zoom, setZoom] = useState(1.0);
      const [viewBox, setViewBox] = useState({ x: 0, y: 0, w: 800, h: 600 });
      const [dragging, setDragging] = useState(false);
      const [dragStart, setDragStart] = useState({ x: 0, y: 0 });
      const positions = useRef({});

      useEffect(() => {
        nodes.forEach((n, i) => {
          if (!positions.current[n.node_id]) {
            const angle = (i / nodes.length) * 2 * Math.PI;
            const r = Math.min(280, nodes.length * 9);
            positions.current[n.node_id] = {
              x: 400 + r * Math.cos(angle), y: 300 + r * Math.sin(angle),
            };
          }
        });
      }, [nodes]);

      const nodeR = (node) => {
        const t = node.node_type || '';
        if (['Root','Document','Scene','HyperspectralScene'].includes(t)) return 18;
        if (['Section','Collection','RadarScene','SonarScene'].includes(t)) return 12;
        return 8;
      };

      return React.createElement('svg', {
        ref: svgRef, className: 'graph-canvas',
        style: { width: '100%', height: '100%', background: 'transparent' },
        onWheel: (e) => { e.preventDefault(); setZoom(z => Math.max(0.1, Math.min(10, z * (e.deltaY > 0 ? 1.1 : 0.9)))); },
        onMouseDown: (e) => { setDragging(true); setDragStart({ x: e.clientX, y: e.clientY }); },
        onMouseMove: (e) => {
          if (!dragging) return;
          const dx = (e.clientX - dragStart.x) / zoom;
          const dy = (e.clientY - dragStart.y) / zoom;
          setViewBox(vb => ({ ...vb, x: vb.x - dx, y: vb.y - dy }));
          setDragStart({ x: e.clientX, y: e.clientY });
        },
        onMouseUp: () => setDragging(false),
      },
        React.createElement('defs', null,
          React.createElement('marker', { id: 'arrow', markerWidth: 6, markerHeight: 6, refX: 6, refY: 3, orient: 'auto' },
            React.createElement('path', { d: 'M0,0 L6,3 L0,6 Z', fill: '#666' })
          )
        ),
        React.createElement('g', { className: 'edges' },
          edges.map(edge => {
            const from = positions.current[edge.from_node];
            const to = positions.current[edge.to_node];
            if (!from || !to) return null;
            const dx = to.x - from.x; const dy = to.y - from.y;
            const len = Math.sqrt(dx*dx + dy*dy) || 1;
            const ux = dx/len; const uy = dy/len;
            const fr = nodeR(nodes.find(n => n.node_id === edge.from_node) || {});
            const style = edgeStyle(edge.edge_type);
            return React.createElement('g', { key: edge.edge_id, onClick: () => {} },
              React.createElement('line', {
                x1: from.x + ux * fr, y1: from.y + uy * fr,
                x2: to.x - ux * 10, y2: to.y - uy * 10,
                stroke: style.stroke, strokeWidth: style.strokeWidth,
                strokeDasharray: style.strokeDasharray,
                markerEnd: 'url(#arrow)',
              }),
              React.createElement('title', null, edge.edge_type)
            );
          }).filter(Boolean)
        ),
        React.createElement('g', { className: 'nodes' },
          nodes.map(node => {
            const pos = positions.current[node.node_id];
            if (!pos) return null;
            const r = nodeR(node);
            const isSelected = node.node_id === selectedNodeId;
            const color = MODALITY_COLORS[modality] || MODALITY_COLORS.default;
            return React.createElement('g', {
              key: node.node_id,
              transform: `translate(${pos.x}, ${pos.y})`,
              onClick: () => onNodeSelect?.(node),
              style: { cursor: 'pointer' },
            },
              React.createElement('circle', {
                r, fill: isSelected ? '#fff' : color,
                stroke: isSelected ? '#fff' : 'rgba(255,255,255,0.3)',
                strokeWidth: isSelected ? 2 : 1,
                opacity: node.provisional ? 0.5 : 1,
              }),
              zoom > 1.5 && React.createElement('text', {
                y: r + 10, textAnchor: 'middle', fontSize: 9,
                fill: 'rgba(255,255,255,0.7)',
              }, (node.content || node.node_type || '').slice(0, 20)),
              React.createElement('title', null,
                `${node.node_type}: ${(node.content || '').slice(0, 80)}`)
            );
          }).filter(Boolean)
        )
      );
    }

    function FabricView({ graphs, onGraphSelect }) {
      const positions = graphs.map((_, i) => {
        const angle = (i / graphs.length) * 2 * Math.PI;
        return { x: 250 + 180 * Math.cos(angle), y: 200 + 180 * Math.sin(angle) };
      });
      return React.createElement('svg', { viewBox: '0 0 500 400', style: { width: '100%', height: '100%' } },
        graphs.map((g, i) =>
