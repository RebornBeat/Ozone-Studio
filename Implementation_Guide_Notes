## C.5 Consecutive Loop Infrastructure

```rust
async fn extract_until_stable<T, F, Fut, K>(
    &self,
    input_text: &str,
    extractor: F,
    dedup_key: fn(&T) -> K,
    safety_max_rounds: usize,
) -> Vec<T>
where
    T: Clone + std::fmt::Debug + Send,
    F: Fn(String, Vec<T>) -> Fut + Send,
    Fut: std::future::Future<Output = Vec<T>> + Send,
    K: Eq + std::hash::Hash,
{
    let mut accumulated: Vec<T> = Vec::new();
    let mut no_new_consecutive = 0;
    let stable_threshold = 5;

    for _round in 0..safety_max_rounds {
        let candidates = extractor(input_text.to_string(), accumulated.clone()).await;
        let existing_keys: std::collections::HashSet<K> =
            accumulated.iter().map(|i| dedup_key(i)).collect();
        let truly_new: Vec<T> = candidates.into_iter()
            .filter(|item| !existing_keys.contains(&dedup_key(item))).collect();

        if truly_new.is_empty() {
            no_new_consecutive += 1;
            if no_new_consecutive >= stable_threshold { break; }
        } else {
            no_new_consecutive = 0;
            accumulated.extend(truly_new);
        }
    }
    accumulated
}
