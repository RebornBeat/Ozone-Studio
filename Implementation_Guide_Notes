    ),
    selectedFeature && React.createElement('div', { className: 'feature-detail' },
      React.createElement('h4', null, selectedFeature.node_type),
      React.createElement('p', null, selectedFeature.content),
      selectedFeature.materialized_path && React.createElement('code', null, selectedFeature.materialized_path)
