## I.2 Clarification Processing Logic

```rust
/// INVARIANT: new insights captured but we ALWAYS return to close the
/// current clarification before proceeding. Human cannot derail AMT.
async fn process_clarification_response(
    &self, state: &mut OrchestrationState, response: ClarificationResponse,
) -> OzoneResult<()> {
    let request = state.pending_clarifications.iter()
        .find(|r| r.request_id == response.request_id).cloned()
        .ok_or(OzoneError::ClarificationNotFound)?;

    // 1. Apply selected option's AMT expansion
    if let Some(ref label) = response.selected_option {
        if let Some(opt) = request.multiple_choice_options.iter().find(|o| o.label == *label) {
            if let Some(ref expansion) = opt.amt_expansion {
                self.expand_amt_branch(state, &request.amt_branch_path, expansion).await?;
            }
        }
    }

    // 2. Extract NEW INSIGHTS from free text — add to AMT but don't follow yet
    if let Some(ref free_text) = response.free_text {
        let new_intents = self.extract_new_intents_from_clarification_text(
            free_text, &request.current_intent_text).await?;
        for intent in &new_intents {
            self.add_intent_to_amt(state, intent).await?;
            // NOTE: Acknowledge but don't follow until current clarification closed
        }
    }

    // 3. Close clarification
    state.pending_clarifications.retain(|r| r.request_id != response.request_id);
    if state.pending_clarifications.is_empty() {
        state.awaiting_clarification = false;
    }
    Ok(())
}
