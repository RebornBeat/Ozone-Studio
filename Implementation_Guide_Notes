## C.7 Unknown Modality Handling (from Z.ai)

When a detected modality has no registered handler:

```rust
async fn handle_unknown_modality(&self, modality: &str, state: &mut OrchestrationState) {
    // 1. Create a generic unknown container in ZSEI
    let container_id = self.zsei.create_container(
        ContainerType::UnknownModality,
        &format!("/Modalities/Unknown/{}", modality),
    ).await;

    // 2. Trigger META clarification via ZSEI self-review:
    //    ZSEI inspects its own modality registry for similar handlers
    let similar = self.zsei.find_similar_handlers(modality).await;

    if let Some(best_match) = similar.first() {
        // Suggest re-routing to closest modality
        state.pending_clarifications.push(ClarificationRequest {
            template: ClarificationTemplate::MultipleChoice,
            clarification_question: format!(
                "Detected content type '{}' has no registered handler. \
                 Closest match: '{}'. Route to that, or treat as generic?",
                modality, best_match.name
            ),
            multiple_choice_options: vec![
                ClarificationOption { label: "A".into(), text: format!("Route to {}", best_match.name), ..Default::default() },
                ClarificationOption { label: "B".into(), text: "Treat as generic text/data".into(), ..Default::default() },
                ClarificationOption { label: "C".into(), text: "Skip this content".into(), ..Default::default() },
            ],
            allows_free_text: false,
            ..Default::default()
        });
    } else {
        // No similar handler — always treat unknown as generic text
        // Store in unknown container, continue without halting
        state.attached_files.push(AttachedFileInfo {
            modality: "text".to_string(),
            is_supplementary: true,
            ..Default::default()
        });
    }
}
