## C.7 Full Per-Chunk Processing Flow

```rust
/// Process a single chunk through all normalization steps.
/// Returns a ChunkGraph containing all extracted knowledge.
async fn process_chunk(
    &self,
    raw_text: String,
    chunk_index: u32,
    prompt_start_char: usize,
    prompt_end_char: usize,
    next_chunk_preview: Option<&str>,
) -> ChunkGraph {
    let graph_id = self.generate_id().await;

    // STEP 1: Resolve overlap with next chunk (if any)
    let overlap_resolution = if let Some(next_preview) = next_chunk_preview {
        let resolution = self.resolve_overlap_boundary(
            &raw_text,
            next_preview,
            // overlap window = min(20% of chunk, 500 chars)
            (raw_text.len() / 5).min(500),
        ).await;
        Some(resolution)
    } else {
        None
    };

    // Apply resolution — trim current chunk if needed
    let cleaned_text = if let Some(ref res) = overlap_resolution {
        raw_text[..res.current_keep_end.min(raw_text.len())].to_string()
    } else {
        raw_text.clone()
    };

    // STEP 2: Extract sentence boundaries (zero-shot)
    let sentence_boundaries = self.extract_sentence_boundaries(&cleaned_text).await;
    let paragraph_breaks = self.extract_paragraph_breaks(&cleaned_text).await;

    // STEP 3: Keywords — consecutive 5x stable
    let keywords = self.extract_until_stable(
        &cleaned_text,
        |text, _| async move { self.extract_keywords_zero_shot(&text).await },
        |k: &String| k.clone(),
        20,
    ).await;

    // STEP 4: Topics — consecutive 5x stable
    let topics = self.extract_until_stable(
        &cleaned_text,
        |text, _| async move { self.extract_topics_zero_shot(&text).await },
        |t: &String| t.clone(),
        15,
    ).await;

    // STEP 5: Grammar relationships
    let grammar_relationships = self.extract_grammar_relationships(&cleaned_text, chunk_index).await;

    // STEP 6: Modality detection — consecutive 5x stable
    let modality_detections = self.detect_modalities_stable(&cleaned_text, chunk_index).await;

    // STEP 7: Entity extraction
    let entity_nodes = self.extract_entities_zero_shot(&cleaned_text, chunk_index).await;

    let root_modality_list_contribution = modality_detections.iter()
        .map(|d| d.modality.clone())
        .collect::<std::collections::HashSet<_>>()
        .into_iter()
        .collect();

    ChunkGraph {
        graph_id,
        chunk_index,
        prompt_start_char,
        prompt_end_char,
        sentence_boundaries,
        paragraph_breaks,
        cleaned_text,
        overlap_resolution,
        keywords,
        topics,
        entity_nodes,
        grammar_relationships,
        modality_detections,
        root_modality_list_contribution,
        provenance: EdgeProvenance::DerivedFromPrompt,
        state: GraphStateType::Created,
        created_at: Self::now_iso8601(),
    }
}
```

## C.8 Root Modality Aggregation

After all chunks are processed, aggregate the root modality list:

```rust
/// Aggregate all detected modalities across all chunk graphs.
/// Creates the root modality list before Initial Graph Creation.
async fn aggregate_root_modalities(
    &self,
    chunk_graphs: &[ChunkGraph],
) -> RootModalityList {
    // Collect unique modalities across all chunks
    let mut modality_map: HashMap<String, Vec<ModalityEvidence>> = HashMap::new();

    for chunk in chunk_graphs {
        for detection in &chunk.modality_detections {
            modality_map
                .entry(detection.modality.clone())
                .or_default()
                .push(ModalityEvidence {
                    chunk_index: chunk.chunk_index,
                    span_start: detection.span_start,
                    span_end: detection.span_end,
                    intent_reference: detection.intent_reference.clone(),
                });
        }
    }

    // Verify handlers exist for all detected modalities
    let mut verified = Vec::new();
    let mut unhandled = Vec::new();
    for (modality, evidence) in modality_map {
        if self.pipeline_registry.has_modality_handler(&modality).await {
            verified.push(VerifiedModality { modality, evidence });
        } else {
            unhandled.push(UnhandledModality { modality, evidence });
        }
    }

    RootModalityList {
        verified_modalities: verified,
        unhandled_modalities: unhandled,
        total_chunk_count: chunk_graphs.len() as u32,
    }
}

