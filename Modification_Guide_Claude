            })
          ),
          // Modality nodes (clusters)
          graphs.map((g, i) =>
            React.createElement('g', {
              key: g.graph_id,
              transform: `translate(${positions[i].x}, ${positions[i].y})`,
              onClick: () => onGraphSelect(g),
