    // ─── FABRIC VIEW (cross-modal topology) ────────────────────────────────
    function FabricView({ graphs, crossModalEdgeCount, onGraphSelect }) {
      // Position graphs in a constellation layout
      const positions = [];
      graphs.forEach((g, i) => {
        const angle = (i / graphs.length) * 2 * Math.PI;
        const r = 180;
        positions.push({ x: 250 + r * Math.cos(angle), y: 200 + r * Math.sin(angle) });
      });

      const MODALITY_COLORS = {
        text: '#2ecc71', code: '#3498db', image: '#e67e22', audio: '#9b59b6',
        video: '#e74c3c', math: '#f1c40f', chemistry: '#1abc9c', dna: '#27ae60',
