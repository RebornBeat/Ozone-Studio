## I.2 Clarification Processing Logic

```rust
/// Process a human clarification response.
/// INVARIANT: new insights from response are captured, but we ALWAYS return
/// to close the clarification before proceeding. Human cannot derail AMT.
async fn process_clarification_response(
    &self,
    state: &mut OrchestrationState,
    response: ClarificationResponse,
) -> OzoneResult<()> {
    let request = state.pending_clarifications
        .iter()
        .find(|r| r.request_id == response.request_id)
        .cloned()
        .ok_or(OzoneError::ClarificationNotFound)?;

    // STEP 1: Process selected option (if multiple choice)
    if let Some(ref option_label) = response.selected_option {
        let option = request.multiple_choice_options.iter()
            .find(|o| o.label == *option_label);
        if let Some(opt) = option {
            // Apply the option's AMT expansion
            if let Some(ref expansion) = opt.amt_expansion {
                self.expand_amt_branch(state, &request.amt_branch_path, expansion).await?;
            }
        }
    }

    // STEP 2: If free text provided, scan for NEW INSIGHTS
    if let Some(ref free_text) = response.free_text {
        let new_intents = self.extract_new_intents_from_clarification_text(
            free_text,
            &request.current_intent_text,
        ).await?;

        for intent in &new_intents {
            // ADD divergent content to AMT (don't ignore it)
            self.add_intent_to_amt(state, intent).await?;
        }

        // NOTE: We ACKNOWLEDGE new insights but DO NOT follow them
        // until the current clarification is fully closed.
        // The human is informed: "I've noted [new insight] and will address it
        // after we resolve [clarification question]"
    }

    // STEP 3: Mark clarification as resolved
    if let Some(cl) = state.pending_clarifications.iter_mut()
        .find(|r| r.request_id == response.request_id)
    {
        // Mark handled (remove from pending list after processing)
    }
    state.pending_clarifications.retain(|r| r.request_id != response.request_id);

    // STEP 4: Resume execution if no more pending clarifications
    if state.pending_clarifications.is_empty() {
        state.awaiting_clarification = false;
    }

    Ok(())
}
