## D.3 Orchestrator: create_initial_modality_graphs

```rust
/// Phase 2: Create all initial modality graphs before AMT building.
/// This is the system's initial knowledge state before intent extraction.
async fn create_initial_modality_graphs(
    &self,
    state: &mut OrchestrationState,
) -> OzoneResult<()> {

    // ── PASS 1: Parallel structural creation ──
    let mut structural_tasks = Vec::new();

    for verified_modality in &state.root_modality_list.verified_modalities {
        let modality = verified_modality.modality.clone();
        let pipeline_id = self.modality_name_to_pipeline_id(&modality);
        let evidence = verified_modality.evidence.clone();
        let project_id = state.project_id;

        structural_tasks.push(async move {
            // Extract modality content from detected spans in chunk graphs
            let content = self.extract_modality_content_from_spans(
                &evidence,
                &state.chunk_graphs,
                &state.original_prompt,
            ).await?;

            // Execute: Analyze → CreateGraph (structural only)
            let analyze_input = serde_json::json!({
                "action": { "type": "Analyze", "data": content },
                "project_id": project_id,
                "structural_only": true,  // no semantic pass yet
            });
            let analysis_result = self.executor.execute(pipeline_id, analyze_input).await?;

            let graph_input = serde_json::json!({
                "action": {
                    "type": "CreateGraph",
                    "analysis": analysis_result,
                    "project_id": project_id,
                    "evidence": evidence,
                }
            });
            let graph_result = self.executor.execute(pipeline_id, graph_input).await?;
            let graph_id = graph_result["graph_id"].as_u64()
                .ok_or(OzoneError::MissingGraphId)?;

            OzoneResult::Ok((modality, graph_id))
        });
    }

    // Await all structural creations in parallel
    let structural_results = futures::future::join_all(structural_tasks).await;
    for result in structural_results {
        let (modality, graph_id) = result?;
        state.graphs.insert(modality.clone(), graph_id);
        state.graph_states.insert(graph_id, GraphState {
            graph_id,
            modality: modality.clone(),
            current_state: GraphStateType::Created,
            ..Default::default()
        });
    }

    // ── PASS 2: Semantic enrichment ──
    // Text modality first (sequential)
    if let Some(&text_graph_id) = state.graphs.get("text") {
        self.run_semantic_enrichment_for_graph(state, text_graph_id, "text").await?;
        self.update_graph_state(state, text_graph_id, GraphStateType::SemanticEnriched).await?;
    }

    // All other modalities in parallel
    let other_modalities: Vec<(String, u64)> = state.graphs.iter()
        .filter(|(k, _)| *k != "text")
        .map(|(k, v)| (k.clone(), *v))
        .collect();

    let semantic_tasks: Vec<_> = other_modalities.iter()
        .map(|(modality, graph_id)| {
            self.run_semantic_enrichment_for_graph(state, *graph_id, modality)
        })
        .collect();

    futures::future::join_all(semantic_tasks).await
        .into_iter()
        .collect::<OzoneResult<Vec<_>>>()?;

    for (_, graph_id) in &other_modalities {
        self.update_graph_state(state, *graph_id, GraphStateType::SemanticEnriched).await?;
    }

    // ── PASS 3: Cross-modal references (iterative until 5x stable) ──
    self.build_cross_modal_references_until_stable(state).await?;

    Ok(())
}

/// Cross-modal reference building with 5x consecutive stable loop.
async fn build_cross_modal_references_until_stable(
    &self,
    state: &mut OrchestrationState,
) -> OzoneResult<()> {
    let mut stable_count = 0;
    let mut pass = 0;

    loop {
        pass += 1;
        let new_edges_this_pass = self.run_cross_modal_reference_pass(state, pass).await?;

        if new_edges_this_pass == 0 {
            stable_count += 1;
            if stable_count >= 5 {
                break;
            }
        } else {
            stable_count = 0;
        }
    }

    // Mark all graphs as CrossLinked → Stable
    for graph_id in state.graphs.values() {
        self.update_graph_state(state, *graph_id, GraphStateType::CrossLinked).await?;
        self.update_graph_state(state, *graph_id, GraphStateType::Stable).await?;
    }

    Ok(())
}

/// Single cross-modal reference pass.
/// Returns count of new cross-modal edges created.
async fn run_cross_modal_reference_pass(
    &self,
    state: &mut OrchestrationState,
    pass_number: u32,
) -> OzoneResult<usize> {
    let mut new_edges = 0;

    // Phase A: Text → all other modalities
    if let Some(&text_graph_id) = state.graphs.get("text") {
        for (target_modality, &target_graph_id) in state.graphs.iter() {
            if target_modality == "text" { continue; }
            let edges = self.link_text_to_modality(
                state, text_graph_id, target_graph_id, target_modality
            ).await?;
            new_edges += edges;
        }
    }

    // Phase B: All → text (back-references)
    if let Some(&text_graph_id) = state.graphs.get("text") {
        for (source_modality, &source_graph_id) in state.graphs.iter() {
            if source_modality == "text" { continue; }
            let edges = self.link_modality_to_text(
                state, source_graph_id, text_graph_id, source_modality
            ).await?;
            new_edges += edges;
        }
    }

    // Phase C (pass 3+): Inter-modality connections
    if pass_number >= 3 {
        let graph_pairs: Vec<(String, u64, String, u64)> = state.graphs.iter()
            .flat_map(|(a_name, &a_id)| {
                state.graphs.iter()
                    .filter(|(b_name, _)| *b_name > a_name && **b_name != "text")
                    .map(|(b_name, &b_id)| (a_name.clone(), a_id, b_name.clone(), b_id))
                    .collect::<Vec<_>>()
            })
            .collect();

        for (a_name, a_id, b_name, b_id) in graph_pairs {
            let edges = self.link_inter_modality(state, a_id, &a_name, b_id, &b_name).await?;
            new_edges += edges;
        }
    }

    Ok(new_edges)
}
