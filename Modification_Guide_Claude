              React.createElement('span', { className: 'engine-label' }, eng.label)
            )
          )
        ),
        // Engine content
        activeEngine && React.createElement(EngineContent, {
          engine: activeEngine,
          executePipeline,
        })
      );
    }

    function EngineContent({ engine, executePipeline }) {
      switch (engine.modality) {
        case '3d':           return React.createElement(ThreeDEngineUI, { engine, executePipeline });
        case 'eeg':          return React.createElement(NeuralSignalEngineUI, { engine, executePipeline });
        case 'bci':          return React.createElement(NeuralSignalEngineUI, { engine, executePipeline });
        case 'dna':          return React.createElement(GenomeBrowserUI, { engine, executePipeline });
        case 'chemistry':    return React.createElement(MolecularViewerUI, { engine, executePipeline });
        case 'math':         return React.createElement(ProofEngineUI, { engine, executePipeline });
        case 'code':         return React.createElement(CodeIntelEngineUI, { engine, executePipeline });
        case 'parametric_cad': return React.createElement(CADEngineUI, { engine, executePipeline });
        case 'kinematics':   return React.createElement(KinematicsEngineUI, { engine, executePipeline });
        case 'geospatial':   return React.createElement(GeospatialEngineUI, { engine, executePipeline });
        default: return React.createElement('div', null, `Engine for ${engine.modality} not yet implemented`);
      }
    }

    const root = ReactDOM.createRoot(container);
    root.render(React.createElement(EnginesUI));
    return () => root.unmount();
  },
};
