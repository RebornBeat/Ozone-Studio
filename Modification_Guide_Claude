        Ok(result) => {
            let raw = result.get("response").and_then(|r| r.as_str()).unwrap_or("[]");
            let json_str = Self::extract_json_from_response(raw, '[', ']');
            serde_json::from_str::<Vec<serde_json::Value>>(&json_str)
                .unwrap_or_default()
                .into_iter()
                .filter_map(|v| {
