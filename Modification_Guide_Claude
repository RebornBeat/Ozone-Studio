### F.1.5 create_graph — Grammar Edges and Modality References

```rust
async fn create_graph(
    &self,
    analysis: TextAnalysisResult,
    project_id: u64,
    is_supplementary: bool,
) -> TextModalityOutput {
    let mut nodes: Vec<TextGraphNode> = Vec::new();
    let mut edges: Vec<TextGraphEdge> = Vec::new();
    let mut node_id: u64 = 1;
    let mut edge_id: u64 = 1;

    // ── ROOT NODE ──
    let root_node_id = node_id;
    nodes.push(TextGraphNode {
        node_id: root_node_id,
        node_type: TextNodeType::Document,
        content: analysis.document_text[..analysis.document_text.len().min(200)].to_string(),
        // Root carries all detection metadata
        detected_modalities_metadata: analysis.root_modality_contribution.clone(),
        chunk_graph_ids: analysis.chunk_graph_ids.clone(),
        true_text_spans: analysis.true_text_spans.clone(),
        materialized_path: Some(format!("/TextGraph/Project_{}/Document", project_id)),
        provisional: false,
        provisional_status: ProvisionalStatus::Finalized,
        version: 1,
        provenance: EdgeProvenance::DerivedFromPrompt,
        ..Default::default()
    });
    node_id += 1;

    // ── STRUCTURAL NODES (existing logic) ──
    // ... sections, paragraphs, sentences, etc. ...

    // ── GRAMMAR-DERIVED EDGES (NEW) ──
    for rel in &analysis.grammar_relationships {
        // Find or create from_node and to_node
        let from_node_id = nodes.iter()
            .find(|n| n.content.contains(&rel.from_text))
            .map(|n| n.node_id);

        let to_node_id = nodes.iter()
            .find(|n| n.content.contains(&rel.to_text))
            .map(|n| n.node_id);

        // If nodes don't exist as structural nodes, create InferredConcept nodes
        let from_id = from_node_id.unwrap_or_else(|| {
            let id = node_id;
            nodes.push(TextGraphNode {
                node_id: id,
                node_type: TextNodeType::InferredConcept,
                content: rel.from_text.clone(),
                materialized_path: Some(format!("/TextGraph/InferredConcept/{}", id)),
                provenance: EdgeProvenance::DerivedFromChunk(
                    rel.provenance.chunk_index().unwrap_or(0)
                ),
                provisional: false,
                provisional_status: ProvisionalStatus::Validated,
                version: 1,
                ..Default::default()
            });
            node_id += 1;
            id
        });

        let to_id = to_node_id.unwrap_or_else(|| {
            let id = node_id;
            nodes.push(TextGraphNode {
                node_id: id,
                node_type: TextNodeType::InferredConcept,
                content: rel.to_text.clone(),
                materialized_path: Some(format!("/TextGraph/InferredConcept/{}", id)),
                provenance: EdgeProvenance::DerivedFromChunk(
                    rel.provenance.chunk_index().unwrap_or(0)
                ),
                provisional: false,
                provisional_status: ProvisionalStatus::Validated,
                version: 1,
                ..Default::default()
            });
            node_id += 1;
            id
        });

        let edge_type = Self::map_edge_type_string(&rel.edge_type);
        edges.push(TextGraphEdge {
            edge_id,
            from_node: from_id,
            to_node: to_id,
            edge_type,
            provenance: rel.provenance.clone(),
            version: 1,
            properties: {
                let mut p = HashMap::new();
                if let Some(ref t) = rel.tense { p.insert("tense".into(), serde_json::json!(t)); }
                p.insert("negated".into(), serde_json::json!(rel.negated));
                if let (Some(s), Some(e)) = (rel.source_sentence_start, rel.source_sentence_end) {
                    p.insert("source_span".into(), serde_json::json!([s, e]));
                }
                p
            },
            ..Default::default()
        });
        edge_id += 1;
    }

    // ── MODALITY REFERENCE NODES (NEW) ──
    for detection in &analysis.detected_modalities {
        if detection.modality == "true_text" { continue; } // true text is structural, not a reference

        let ref_node_id = node_id;
        nodes.push(TextGraphNode {
            node_id: ref_node_id,
            node_type: TextNodeType::ModalityReference,
            content: format!("[{}] span:{}-{}", detection.modality, detection.span_start, detection.span_end),
            // No content_snippet — positions are stored, content retrieved dynamically
            position: Some(TextPosition {
                start_offset: detection.span_start,
                end_offset: detection.span_end,
                chunk_index: Some(detection.chunk_index),
                ..Default::default()
            }),
            materialized_path: Some(format!("/TextGraph/ModalityRef/{}/{}", detection.modality, ref_node_id)),
            provenance: EdgeProvenance::DerivedFromChunk(detection.chunk_index),
            provisional: false,
            provisional_status: ProvisionalStatus::Validated,
            version: 1,
            ..Default::default()
        });

        edges.push(TextGraphEdge {
            edge_id,
            from_node: root_node_id,
            to_node: ref_node_id,
            edge_type: TextEdgeType::ReferencesModality,
            provenance: EdgeProvenance::DerivedFromChunkGraph(0), // chunk graph ID populated later
            version: 1,
            properties: {
                let mut p = HashMap::new();
                p.insert("target_modality".into(), serde_json::json!(&detection.modality));
                p.insert("intent_reference".into(), serde_json::json!(&detection.intent_reference));
                p
            },
            ..Default::default()
        });

        edge_id += 1;
        node_id += 1;
    }

    // ── TRIGGER ZSEI HOOKS ──
    // Hook 1: OnGraphCreated
    // Hook 2: OnInferRelationships
    // Hook 3: OnEdgeCompletion
    // (Hook 4 fires during cross-modal pass)

    // ... build and return output ...
}
