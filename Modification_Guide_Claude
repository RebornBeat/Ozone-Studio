## C.2 Chunk Overlap Resolution (LLM Zero-Shot)

The existing rule-based `find_best_boundary` is replaced entirely with LLM-based resolution. No heuristics.

```rust
/// Resolve overlap between adjacent chunks using LLM zero-shot.
/// Returns the clean boundaries — no duplicate content.
async fn resolve_overlap_boundary(
    &self,
    current_chunk_text: &str,
    next_chunk_text: &str,
    overlap_chars: usize,
) -> OverlapResolution {
    let current_tail = if current_chunk_text.len() > overlap_chars {
        &current_chunk_text[current_chunk_text.len() - overlap_chars..]
    } else {
        current_chunk_text
    };
    let next_head = if next_chunk_text.len() > overlap_chars {
        &next_chunk_text[..overlap_chars]
    } else {
        next_chunk_text
    };

    let prompt = format!(r#"
You are analyzing the overlapping region between two adjacent text chunks.
Determine the clean split boundary to eliminate any duplicated content.

END OF CURRENT CHUNK:
---
{}
---

START OF NEXT CHUNK:
---
{}
---

Determine:
1. Is there any duplicated content in these two windows?
2. If yes, where should the clean boundary be?
3. Which chunk should "own" any content that appears in both?

Return ONLY valid JSON (no explanation, no markdown):
{{
  "has_overlap": true | false,
  "overlap_type": "sentence_cutoff | paragraph_cutoff | mid_sentence | mid_word | no_overlap",
  "current_should_end_at_offset": <integer — how many chars from the start of current_tail to keep>,
  "next_should_start_at_offset": <integer — how many chars into next_head to skip>,
  "owned_by": "current | next | neither",
  "explanation": "one sentence describing the boundary decision"
}}"#, current_tail, next_head);

    let input = serde_json::json!({
        "prompt": prompt,
        "max_tokens": 250,
        "temperature": 0.05,
        "system_context": "Text boundary analysis. Return only valid JSON object.",
    });

    match self.executor.execute(9, input).await {
        Ok(result) => {
            let json_str = Self::extract_json_from_response(
                result.get("response").and_then(|r| r.as_str()).unwrap_or("{}"),
                '{', '}',
            );
            serde_json::from_str::<serde_json::Value>(&json_str).ok()
                .map(|v| OverlapResolution {
                    has_overlap: v["has_overlap"].as_bool().unwrap_or(false),
                    overlap_type: v["overlap_type"].as_str().unwrap_or("no_overlap").to_string(),
                    // Absolute positions in original chunk texts:
                    current_keep_end: current_chunk_text.len().saturating_sub(overlap_chars)
                        + v["current_should_end_at_offset"].as_usize().unwrap_or(current_tail.len()),
                    next_start_offset: v["next_should_start_at_offset"].as_usize().unwrap_or(0),
                    owned_by: v["owned_by"].as_str().unwrap_or("current").to_string(),
                })
                .unwrap_or_default()
        }
        Err(_) => OverlapResolution::default(), // keep in current, start next fresh
    }
}

#[derive(Debug, Clone, Default)]
pub struct OverlapResolution {
    pub has_overlap: bool,
    pub overlap_type: String,
    pub current_keep_end: usize,    // current chunk ends here (char index in current_chunk_text)
    pub next_start_offset: usize,   // next chunk starts here (char offset in next_chunk_text)
    pub owned_by: String,           // "current" | "next" | "neither"
}
