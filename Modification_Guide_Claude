## S.1 Updated ContextAggregationPipeline

The pipeline is updated to support the new graph-based context and smart chunk reconstruction:

```rust
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(tag = "action")]
pub enum ContextAggInput {
    // EXISTING — updated with context_scope
    ForTask {
        task_id: u64,
        token_budget: u32,
        prioritize: Vec<String>,
        include_consciousness: Option<bool>,
        context_scope: Option<String>,      // NEW: "Global" | "Project" | "Workspace"
    },
    ForQuery {
        query: String,
        token_budget: u32,
        container_ids: Option<Vec<u64>>,
        project_id: Option<u64>,
    },
    ForProject {
        project_id: u64,
        token_budget: u32,
        include_files: Option<bool>,
        include_urls: Option<bool>,
    },
    Custom { container_ids: Vec<u64>, token_budget: u32, include_relationships: bool },
    ForBlueprint { blueprint_id: u64, step_index: u32, token_budget: u32 },

    // NEW: Smart chunk reconstruction for a step
    ForStep {
        task_id: u64,
        step_index: u32,
        token_budget: u32,
        relevant_modalities: Vec<String>,   // which modality graphs to include
        prioritize_graphs: Vec<u64>,        // specific graph IDs to prioritize
    },

    // NEW: Reconstruct context at specific token limit
    ReconstructAtLimit {
        task_id: u64,
        target_tokens: u32,
        model_id: Option<String>,           // optional: model-specific token estimation
    },
}

// ForStep implementation:
ContextAggInput::ForStep { task_id, step_index, token_budget, relevant_modalities, prioritize_graphs } => {
    let mut budget = token_budget;
    let mut parts = Vec::new();

    // 1. Prioritized graph nodes (from relevant modalities)
    for graph_id in &prioritize_graphs {
        let graph_context = self.extract_graph_summary(*graph_id, budget / 3).await?;
        budget = budget.saturating_sub(graph_context.tokens);
        parts.push(graph_context.text);
    }

    // 2. Smart chunk reconstruction at remaining budget
    let chunk_graphs = self.load_chunk_graphs_for_task(task_id).await?;
    let chars_per_token = 4;
    let reconstructed = reconstruct_context_at_token_limit(
        &chunk_graphs,
        budget as usize,
        chars_per_token,
    );
    parts.push(reconstructed.text);

    let context_text = parts.join("\n\n---\n\n");
    let token_count = estimate_tokens(&context_text);

    Ok(ContextAggOutput {
        success: true,
        context: Some(AggregatedContext {
            context_text,
            token_count,
            sources: Vec::new(), // populated from prioritize_graphs + chunk indices
            truncated: token_count >= token_budget,
            coverage_score: 0.9,
            consciousness_context: None,
        }),
        error: None,
    })
}
