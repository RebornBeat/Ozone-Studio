            },
              React.createElement('circle', {
                r: Math.max(24, Math.min(48, Math.sqrt(g.node_count) * 3)),
                fill: MODALITY_COLORS[g.modality] || MODALITY_COLORS.default,
                opacity: 0.85,
                stroke: 'rgba(255,255,255,0.3)',
                strokeWidth: 1,
              }),
              React.createElement('text', {
                textAnchor: 'middle', dy: 4,
                fontSize: 11, fontWeight: 'bold',
                fill: '#000',
