        detectAvailableEngines();
      }, []);

      const detectAvailableEngines = async () => {
        const state = getSharedState();
        const taskId = state.activeTaskId;
        if (!taskId) return;

        const result = await executePipeline(5, { action: 'GetTaskGraphs', task_id: taskId });
        const graphs = result?.graphs || [];
        const engines = graphs
          .filter(g => ENGINE_REGISTRY[g.modality])
          .map(g => ({ ...ENGINE_REGISTRY[g.modality], modality: g.modality, graphId: g.graph_id }));
        setAvailableEngines(engines);
        if (engines.length > 0) setActiveEngine(engines[0]);
