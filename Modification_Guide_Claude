/// Determine context scope from workspace/project selection.
/// Integrates with the WorkspaceTab pipeline (#6).
async fn determine_context_scope(
    &self,
    project_id: Option<u64>,
    workspace_id: Option<u64>,
) -> ContextScope {
    match (project_id, workspace_id) {
        (Some(pid), _) => {
            // Load project's graph history from ZSEI
            // Makes prior project graphs available as initial context
            ContextScope::Project(pid)
        }
        (None, Some(wid)) => {
            ContextScope::Workspace(wid)
        }
        (None, None) => {
            ContextScope::Global
        }
    }
}

/// Load prior context from scope (for non-first-time processing).
async fn load_scoped_prior_context(
    &self,
    scope: &ContextScope,
) -> OzoneResult<Vec<u64>> { // returns prior graph IDs available
    match scope {
        ContextScope::Project(pid) => {
            // Query ZSEI for all modality graphs created in this project
            self.zsei.query_graphs_for_project(*pid).await
        }
        ContextScope::Workspace(wid) => {
            // Query ZSEI for all graphs across workspace's projects
            self.zsei.query_graphs_for_workspace(*wid).await
        }
        ContextScope::Global => Ok(vec![]),
    }
}
