    // ─── MAIN CONTEXT VIEWER ───────────────────────────────────────────────
    function ContextViewerUI() {
      const [activeMode, setActiveMode] = useState('graph'); // graph | fabric | hierarchy | timeline
      const [graphs, setGraphs] = useState([]);
      const [selectedGraphId, setSelectedGraphId] = useState(null);
      const [graphData, setGraphData] = useState(null);  // { nodes, edges }
      const [selectedNodeId, setSelectedNodeId] = useState(null);
      const [selectedNode, setSelectedNode] = useState(null);
      const [loading, setLoading] = useState(true);
      const [error, setError] = useState(null);
      const [modalityFilter, setModalityFilter] = useState({}); // modality → bool
      const [edgeTypeFilter, setEdgeTypeFilter] = useState('all'); // all | structural | semantic | cross-modal
      const [amtBranches, setAmtBranches] = useState([]);
      const [crossModalEdgeCounts, setCrossModalEdgeCounts] = useState({});

      // Load graphs for current task or project
      useEffect(() => {
        loadGraphs();
      }, []);

      const loadGraphs = async () => {
        setLoading(true);
        setError(null);
        try {
          const state = getSharedState();
          const taskId = state.activeTaskId;
          const projectId = state.selectedProjectId;

          let result;
          if (taskId) {
            result = await executePipeline(5, { action: 'GetTaskGraphs', task_id: taskId });
          } else if (projectId) {
            result = await executePipeline(5, { action: 'GetProjectGraphs', project_id: projectId });
          } else {
            result = { graphs: [] };
          }

          const loadedGraphs = result?.graphs || [];
          setGraphs(loadedGraphs);

          // Initialize modality filter (all on)
          const filter = {};
          loadedGraphs.forEach(g => { filter[g.modality] = true; });
          setModalityFilter(filter);

          // Select first graph by default
          if (loadedGraphs.length > 0) {
            selectGraph(loadedGraphs[0].graph_id);
          }

          // Load AMT branches if available
          if (taskId) {
            const amtResult = await executePipeline(5, { action: 'GetAMTBranches', task_id: taskId });
            setAmtBranches(amtResult?.branches || []);
          }
        } catch (e) {
          setError(e.message || 'Failed to load context graphs');
        } finally {
          setLoading(false);
        }
      };

      const selectGraph = async (graphId) => {
        setSelectedGraphId(graphId);
        setSelectedNodeId(null);
        setSelectedNode(null);
        try {
          // Determine pipeline for this graph's modality
          const graph = graphs.find(g => g.graph_id === graphId);
          const pipelineId = graph ? modalityToPipelineId(graph.modality) : 5;
          const result = await executePipeline(pipelineId, {
            action: 'GetGraph',
            graph_id: graphId,
          });
          setGraphData(result);
        } catch (e) {
          setError(e.message || 'Failed to load graph');
        }
      };

      const selectNode = async (node) => {
        setSelectedNodeId(node.node_id);
        setSelectedNode(node);
      };

      const navigateToLinked = async (targetGraphId, targetNodeId) => {
        await selectGraph(targetGraphId);
        // After graph loads, select the target node
        setTimeout(() => setSelectedNodeId(targetNodeId), 300);
      };

      const modalityToPipelineId = (modality) => {
        const map = {
          text: 100, code: 101, image: 102, audio: 103, video: 104,
          math: 105, chemistry: 106, dna: 107, eeg: 108, '3d': 109,
          sound_reconstruction: 110, biology: 111, proteomics: 112,
          haptic: 113, thermal: 114, depth: 115, imu: 116,
          geospatial: 117, electromagnetic: 118, bci: 119,
          parametric_cad: 120, kinematics: 121, control_systems: 122,
          network_topology: 123,
        };
        return map[modality] || 100;
      };

      // Filter nodes/edges based on current filter settings
      const filteredNodes = (graphData?.nodes || []).filter(n => {
        // No modality filter on nodes within a selected graph — they're all same modality
        return true;
      });
      const filteredEdges = (graphData?.edges || []).filter(e => {
        if (edgeTypeFilter === 'all') return true;
        if (edgeTypeFilter === 'structural') {
          return ['Contains','ParentOf','ChildOf','PartOf','Precedes','Follows'].includes(e.edge_type);
        }
        if (edgeTypeFilter === 'semantic') {
          return ['Performs','Affects','Implies','CausedBy','Enables'].includes(e.edge_type);
        }
        if (edgeTypeFilter === 'cross-modal') {
          return ['ReferencesModality','DescribedByText','CrossModalLink'].includes(e.edge_type);
        }
        return true;
      });

      if (loading && graphs.length === 0) {
        return React.createElement('div', { className: 'context-viewer loading' },
          React.createElement('div', { className: 'loading-spinner' }),
          React.createElement('p', null, 'Loading context graphs...')
        );
      }

      if (graphs.length === 0) {
        return React.createElement('div', { className: 'context-viewer empty' },
          React.createElement('span', { className: 'empty-icon' }, '◈'),
          React.createElement('p', null, 'No graphs yet — start a task to build context'),
        );
      }

      return React.createElement('div', { className: 'context-viewer-panel' },

        // TOP: Mode selector + filters
        React.createElement('div', { className: 'context-toolbar' },
          React.createElement('div', { className: 'view-modes' },
            ['graph', 'fabric', 'hierarchy'].map(mode =>
              React.createElement('button', {
                key: mode,
                className: `mode-btn ${activeMode === mode ? 'active' : ''}`,
                onClick: () => setActiveMode(mode),
              }, mode.charAt(0).toUpperCase() + mode.slice(1))
            )
          ),
          activeMode === 'graph' && React.createElement('div', { className: 'edge-type-filter' },
            ['all', 'structural', 'semantic', 'cross-modal'].map(type =>
              React.createElement('button', {
                key: type,
                className: `filter-btn ${edgeTypeFilter === type ? 'active' : ''}`,
                onClick: () => setEdgeTypeFilter(type),
              }, type)
            )
          )
        ),

        // MAIN CONTENT
        React.createElement('div', { className: 'context-main' },

          // LEFT: Modality graph list
          React.createElement('aside', { className: 'graph-list-panel' },
            React.createElement('h4', null, 'Modality Graphs'),
            graphs.map(g =>
              React.createElement('div', {
                key: g.graph_id,
                className: `graph-list-item ${selectedGraphId === g.graph_id ? 'selected' : ''} modality-${g.modality}`,
                onClick: () => selectGraph(g.graph_id),
              },
                React.createElement('span', { className: 'graph-modality-name' }, g.modality),
                React.createElement('div', { className: 'graph-stats' },
                  React.createElement('span', null, `${g.node_count}n`),
                  React.createElement('span', null, `${g.edge_count}e`),
                ),
                React.createElement('span', { className: `graph-state-dot state-${g.state?.toLowerCase()}` })
              )
            ),
            // Cross-modal link summary
            React.createElement('div', { className: 'cross-modal-summary' },
              React.createElement('h5', null, 'Cross-Modal Links'),
              React.createElement('div', { className: 'cross-modal-count' },
                graphs.reduce((sum, g) => sum + (g.cross_modal_edge_count || 0), 0),
                ' total edges'
              )
            )
          ),

          // CENTER: Main visualization
          React.createElement('main', { className: 'context-canvas-area' },
            error && React.createElement('div', { className: 'canvas-error' }, error),

            activeMode === 'graph' && graphData && React.createElement(GraphCanvas, {
              nodes: filteredNodes,
              edges: filteredEdges,
              selectedNodeId,
              onNodeSelect: selectNode,
              onEdgeSelect: (edge) => { /* show edge detail */ },
            }),

            activeMode === 'fabric' && React.createElement(FabricView, {
              graphs: graphs.filter(g => modalityFilter[g.modality] !== false),
              crossModalEdgeCount: crossModalEdgeCounts,
              onGraphSelect: (g) => { selectGraph(g.graph_id); setActiveMode('graph'); },
            }),

            activeMode === 'hierarchy' && React.createElement(HierarchyView, {
              amtBranches,
              graphs,
            }),
          ),

          // RIGHT: Node/edge detail
          React.createElement('aside', { className: 'context-detail-panel' },
            React.createElement(NodeDetailPanel, {
              node: selectedNode,
              graphId: selectedGraphId,
              onClose: () => { setSelectedNode(null); setSelectedNodeId(null); },
              onNavigateToLinked: navigateToLinked,
              executePipeline,
            })
          )
        )
      );
    }

    const root = ReactDOM.createRoot(container);
    root.render(React.createElement(ContextViewerUI));
    return () => root.unmount();
  },

  onActivate: function() { console.log('ContextViewer activated'); },
  onDeactivate: function() { console.log('ContextViewer deactivated'); },
};
