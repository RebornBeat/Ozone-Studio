# SECTION O: CONTEXT VIEWER UI COMPONENT

## O.1 Overview

The Context Viewer is a new core tab that replaces any prior graph-viewing UI. It surfaces all modality graphs for a task or project, with full cross-modal navigation, AMT alignment view, and node/edge inspection. It is the human-facing window into the graph fabric that OZONE maintains as its knowledge structure.

The Context Viewer is **read-optimized** — it reflects what the AGI knows, not a place to manually edit. The AGI edits graphs through pipeline execution. Humans navigate them here.

## O.2 Data Contract — Context Viewer Queries

The Context Viewer calls these pipeline actions:

```javascript
// Get all graphs for a task
executePipeline(5, { action: 'GetTaskGraphs', task_id: taskId })
// → { graphs: [{ graph_id, modality, node_count, edge_count, state, last_modified }] }

// Get full graph (nodes + edges)
executePipeline(N, { action: 'GetGraph', graph_id: graphId })
// → { graph_id, modality, nodes: [...], edges: [...], root: {...} }

// Get node detail
executePipeline(N, { action: 'QueryGraph', graph_id, query: { type: 'NodeDetail', node_id } })
// → { node: {...full node...}, incoming_edges: [...], outgoing_edges: [...], cross_modal_refs: [...] }

// Get cross-modal links for a node
executePipeline(N, { action: 'QueryGraph', graph_id, query: { type: 'CrossModalLinks', node_id } })
// → { links: [{ target_graph_id, target_node_id, edge_type, provenance }] }
```

## O.3 Context Viewer Component

```javascript
/**
 * ContextViewerTab UI Component
 *
 * Displays all modality graphs for a task/project.
 * Four modes: Graph View, Fabric View, Timeline View, Hierarchy View.
 */

module.exports = {
  meta: {
    title: 'Context',
    icon: '◈',
    version: '1.0.0',
  },

  render: function(container, props, React, ReactDOM) {
    const { useState, useEffect, useCallback, useRef } = React;
    const { executePipeline, getSharedState } = props;

    // ─── GRAPH CANVAS (SVG-based) ───────────────────────────────────────────
    function GraphCanvas({ nodes, edges, selectedNodeId, onNodeSelect, onEdgeSelect }) {
      const svgRef = useRef(null);
      const [viewBox, setViewBox] = useState({ x: 0, y: 0, w: 800, h: 600 });
      const [dragging, setDragging] = useState(false);
      const [dragStart, setDragStart] = useState({ x: 0, y: 0 });
      const [zoom, setZoom] = useState(1.0);

      // Node color by modality
      const MODALITY_COLORS = {
        text:           '#2ecc71',  // teal-green
        code:           '#3498db',  // blue
        image:          '#e67e22',  // amber
        audio:          '#9b59b6',  // purple
        video:          '#e74c3c',  // red
        math:           '#f1c40f',  // gold
        chemistry:      '#1abc9c',  // green
        dna:            '#27ae60',  // bio-green
        eeg:            '#8e44ad',  // neural-violet
        '3d':           '#ecf0f1',  // white/light
        geospatial:     '#16a085',  // teal
        parametric_cad: '#d35400',  // deep orange
        kinematics:     '#2980b9',  // darker blue
        bci:            '#6c3483',  // deep purple
        default:        '#95a5a6',  // gray
      };

      // Edge style by type
      const edgeStyle = (edgeType) => {
        if (['Contains','ParentOf','ChildOf','PartOf'].includes(edgeType))
          return { stroke: '#666', strokeWidth: 2, strokeDasharray: 'none' };
        if (['Performs','Affects','CausedBy','Enables','Prevents'].includes(edgeType))
          return { stroke: '#e74c3c', strokeWidth: 1.5, strokeDasharray: '5,3' };
        if (['Implies','LogicallyImplies','Supports'].includes(edgeType))
          return { stroke: '#3498db', strokeWidth: 1.5, strokeDasharray: '8,3' };
        if (['ReferencesModality','DescribedByText','CrossModalLink'].includes(edgeType))
          return { stroke: '#f1c40f', strokeWidth: 2.5, strokeDasharray: 'none' };
        if (['DerivedFrom','VersionOf','RefinesTo'].includes(edgeType))
          return { stroke: '#9b59b6', strokeWidth: 1, strokeDasharray: '3,3' };
        return { stroke: '#555', strokeWidth: 1, strokeDasharray: 'none' };
      };

      const nodeRadius = (node) => {
        if (node.node_type === 'Document' || node.node_type === 'Scene' || node.node_type === 'Root')
          return 18;
        if (node.node_type === 'Section' || node.node_type === 'Collection' || node.node_type === 'ModalityReference')
          return 12;
        return 8;
      };

      const nodeColor = (node, modality) => {
        if (node.provisional) return '#555';
        return MODALITY_COLORS[modality] || MODALITY_COLORS.default;
      };

      // Compute simple force-directed positions if not provided
      const positions = useRef({});
      useEffect(() => {
        if (!nodes.length) return;
        // Initialize positions if not set
        nodes.forEach((n, i) => {
          if (!positions.current[n.node_id]) {
            const angle = (i / nodes.length) * 2 * Math.PI;
            const r = Math.min(300, nodes.length * 10);
            positions.current[n.node_id] = {
              x: 400 + r * Math.cos(angle),
              y: 300 + r * Math.sin(angle),
            };
          }
        });
      }, [nodes]);

      const handleWheel = (e) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? 1.1 : 0.9;
        setZoom(z => Math.max(0.1, Math.min(10, z * delta)));
      };

      return React.createElement('svg', {
        ref: svgRef,
        className: 'graph-canvas',
        style: { width: '100%', height: '100%', background: 'transparent' },
        onWheel: handleWheel,
        onMouseDown: (e) => { setDragging(true); setDragStart({ x: e.clientX, y: e.clientY }); },
        onMouseMove: (e) => {
          if (!dragging) return;
          const dx = (e.clientX - dragStart.x) / zoom;
          const dy = (e.clientY - dragStart.y) / zoom;
          setViewBox(vb => ({ ...vb, x: vb.x - dx, y: vb.y - dy }));
          setDragStart({ x: e.clientX, y: e.clientY });
        },
        onMouseUp: () => setDragging(false),
      },
        // Edges
        React.createElement('g', { className: 'edges' },
          edges.map(edge => {
            const fromPos = positions.current[edge.from_node];
            const toPos = positions.current[edge.to_node];
            if (!fromPos || !toPos) return null;
            const style = edgeStyle(edge.edge_type);
            const dx = toPos.x - fromPos.x;
            const dy = toPos.y - fromPos.y;
            const len = Math.sqrt(dx*dx + dy*dy) || 1;
            const ux = dx/len; const uy = dy/len;
            const fromNode = nodes.find(n => n.node_id === edge.from_node);
            const fr = nodeRadius(fromNode || {});
            const tx = toPos.x - ux * 10; const ty = toPos.y - uy * 10;
            const fx = fromPos.x + ux * fr; const fy = fromPos.y + uy * fr;
            return React.createElement('g', { key: edge.edge_id, onClick: () => onEdgeSelect?.(edge) },
              React.createElement('line', {
                x1: fx, y1: fy, x2: tx, y2: ty,
                stroke: style.stroke,
                strokeWidth: style.strokeWidth,
                strokeDasharray: style.strokeDasharray,
                markerEnd: 'url(#arrowhead)',
              }),
              // Edge label on hover (simple, using title)
              React.createElement('title', null, edge.edge_type)
            );
          }).filter(Boolean)
        ),
        // Arrow marker
        React.createElement('defs', null,
          React.createElement('marker', {
            id: 'arrowhead', markerWidth: 6, markerHeight: 6,
            refX: 6, refY: 3, orient: 'auto',
          },
            React.createElement('path', { d: 'M0,0 L6,3 L0,6 Z', fill: '#666' })
          )
        ),
        // Nodes
        React.createElement('g', { className: 'nodes' },
          nodes.map(node => {
            const pos = positions.current[node.node_id];
            if (!pos) return null;
            const r = nodeRadius(node);
            const isSelected = node.node_id === selectedNodeId;
            return React.createElement('g', {
              key: node.node_id,
              transform: `translate(${pos.x}, ${pos.y})`,
              onClick: () => onNodeSelect?.(node),
              style: { cursor: 'pointer' },
            },
              React.createElement('circle', {
                r,
                fill: isSelected ? '#fff' : nodeColor(node, node.modality || ''),
                stroke: isSelected ? '#fff' : 'rgba(255,255,255,0.3)',
