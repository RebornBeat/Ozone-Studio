## G.2 Step Execution — Hook-Based Living System

The living system is NOT a separate loop. It is hook-based, integrated into the existing step execution flow:

```rust
/// Execute a step and fire the OnStepComplete hook.
/// This IS the living system — it's the step execution + hook, not a wrapper loop.
async fn execute_step_with_hooks(
    &self,
    state: &mut OrchestrationState,
    step: &BlueprintStep,
) -> OzoneResult<StepResult> {
    // Update step state to Active
    self.update_step_status(state, step.step_index, StepStatus::Active).await?;

    // Execute the step
    let result = self.execute_step_inner(state, step).await?;

    // HOOK: OnStepComplete (or OnSubStepComplete for substeps)
    self.on_step_complete(state, step, &result).await?;

    Ok(result)
}

/// Hook: fires on step completion.
/// Detects graph changes and triggers living system cascade.
async fn on_step_complete(
    &self,
    state: &mut OrchestrationState,
    step: &BlueprintStep,
    result: &StepResult,
) -> OzoneResult<()> {
    // 1. Update step status
    self.update_step_status(state, step.step_index, StepStatus::StageComplete(
        result.stage_completed
    )).await?;

    // 2. Detect graph updates (event-driven — only fires if changes detected)
    let graph_updates = self.detect_graph_updates(state, result).await?;

    if !graph_updates.is_empty() {
        // 3. Apply graph updates
        for update in &graph_updates {
            self.apply_graph_update(state, update).await?;
            self.update_graph_state(state, update.graph_id, GraphStateType::Updated).await?;
        }

        // 4. Review AMT alignment
        let amt_expanded = self.review_amt_alignment(state).await?;

        if amt_expanded {
            // 5a. Synthesize new steps for expanded AMT branches
            let new_steps = self.synthesize_steps_from_new_amt_branches(state).await?;
            state.blueprint_steps.extend(new_steps);
            state.progression.steps_total = state.blueprint_steps.len();

            // 5b. Re-verify methodologies for new steps
            self.cross_reference_methodologies_global(state).await?;

            // 5c. Re-verify pipelines for new steps
            self.verify_pipeline_coverage_for_new_steps(state).await?;
        }

        // 6. Update dependent step states
        // This maintains concurrency — steps that depended on updated graphs
        // get their dependency status updated, potentially becoming ready
        self.propagate_graph_updates_to_dependent_steps(state, &graph_updates).await?;

        // 7. Re-validate GraphState → Stable after review
        for update in &graph_updates {
            self.update_graph_state(state, update.graph_id, GraphStateType::ReValidating).await?;
            // Re-validate until stable
            self.revalidate_graph(state, update.graph_id).await?;
        }
    }

    // 8. Add version note to step
    self.add_version_note_to_step(state, step.step_index, result).await?;

    // 9. If step still has pending stages (e.g., depends on another step completing)
    // → update to WaitingOnDependency rather than Complete
    let all_stages_complete = result.all_stages_done;
    if all_stages_complete {
        self.update_step_status(state, step.step_index, StepStatus::Complete).await?;
    } else {
        // Step returns to active/waiting — this is natural in the concurrent flow
        let pending_deps = self.get_step_dependencies(state, step.step_index).await?;
        if pending_deps.is_empty() {
            self.update_step_status(state, step.step_index, StepStatus::Active).await?;
        } else {
            self.update_step_status(state, step.step_index,
                StepStatus::WaitingOnDependency).await?;
        }
    }

    Ok(())
}

/// Main execution driver — runs ready steps concurrently, with hooks.
/// NO maximum iteration limit. Runs until all steps complete.
async fn execute_all_steps(
    &self,
    state: &mut OrchestrationState,
) -> OzoneResult<()> {
    // This is the existing concurrent step execution loop
    // The living system is embedded via on_step_complete hooks
    while !self.all_steps_complete(state) {
        let ready = self.get_ready_steps(state);

        if ready.is_empty() {
            // No ready steps — check for clarification need or deadlock
            if self.has_pending_clarifications(state) {
                self.surface_clarification(state).await?;
                break; // Pause execution, wait for human response
            }
            // Otherwise: all remaining steps are blocked on dependencies
            // Wait for a running step to complete and trigger hooks
            tokio::time::sleep(Duration::from_millis(50)).await;
            continue;
        }

        // Execute all ready steps concurrently
        let step_futures: Vec<_> = ready.iter()
            .map(|step| self.execute_step_with_hooks(state, step))
            .collect();

        // Await with selective error handling — one step failure doesn't kill others
        let results = futures::future::join_all(step_futures).await;
        for result in results {
            if let Err(e) = result {
                tracing::error!("Step execution error: {:?}", e);
                // Mark step as Failed, continue others
            }
        }
    }

    Ok(())
}
