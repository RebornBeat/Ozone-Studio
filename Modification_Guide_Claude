        React.createElement('svg', {
          viewBox: '0 0 500 400',
          style: { width: '100%', height: '100%' },
        },
          // Cross-modal threads (simple: connect all pairs with edges if they have cross-refs)
          graphs.map((ga, i) =>
            graphs.slice(i+1).map((gb, j) => {
              const ia = i; const ib = i + 1 + j;
              const count = crossModalEdgeCount?.[`${ga.graph_id}:${gb.graph_id}`] || 0;
              if (count === 0) return null;
              return React.createElement('line', {
                key: `${ga.graph_id}-${gb.graph_id}`,
                x1: positions[ia].x, y1: positions[ia].y,
                x2: positions[ib].x, y2: positions[ib].y,
                stroke: 'rgba(241,196,15,0.4)',
                strokeWidth: Math.max(1, Math.log(count + 1)),
