**Here is the full, production-ready `BlueprintStore` for ZSEI**, designed to align perfectly with your current architecture and the vision.

### BlueprintStore (full file)

```rust
//! Blueprint Store - ZSEI integration for Blueprints
//!
//! Blueprints are stored as first-class ZSEI containers under the logical path:
//! /Modality/Blueprints/
//!
//! This store provides:
//! - Registration of blueprint metadata as ZSEI containers
//! - Fast lookup and traversal
//! - Relationship linking to methodologies, pipelines, and experiences
//! - Full integration with the three traversal modes

use crate::zsei::{ZSEI, Container, ContainerType, GlobalState, LocalState, ContentReference};
use crate::types::{OzoneResult, OzoneError, ContainerID};
use std::sync::Arc;
use tokio::sync::RwLock;
use serde::{Serialize, Deserialize};
use std::collections::HashMap;

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct BlueprintMetadata {
    pub blueprint_id: u64,
    pub name: String,
    pub signature_hash: String,
    pub input_types: Vec<String>,
    pub output_types: Vec<String>,
    pub keywords: Vec<String>,
    pub success_rate: f32,
    pub use_count: u64,
    pub file: String,                    // relative path to the blueprint JSON
    pub description: Option<String>,
}

pub struct BlueprintStore {
    zsei: Arc<RwLock<ZSEI>>,
    // In-memory cache for fast access (optional, can be removed if you want pure ZSEI)
    cache: RwLock<HashMap<u64, BlueprintMetadata>>,
}

impl BlueprintStore {
    pub fn new(zsei: Arc<RwLock<ZSEI>>) -> Self {
        Self {
            zsei,
            cache: RwLock::new(HashMap::new()),
        }
    }

    /// Register all blueprints from index.json during bootstrap
    pub async fn register_all_from_index(&self, index_path: &std::path::Path) -> OzoneResult<()> {
        let content = std::fs::read_to_string(index_path)
            .map_err(|e| OzoneError::StorageError(format!("Failed to read blueprint index: {}", e)))?;

        let index: serde_json::Value = serde_json::from_str(&content)
            .map_err(|e| OzoneError::StorageError(format!("Failed to parse blueprint index: {}", e)))?;

        let blueprints = index["blueprints"].as_array()
            .ok_or_else(|| OzoneError::StorageError("Invalid blueprint index format".into()))?;

        let zsei = self.zsei.write().await;

        // Find or create the Blueprints root container
        let blueprints_root_id = self.find_or_create_blueprints_root(&zsei).await?;

        for bp in blueprints {
            let metadata: BlueprintMetadata = serde_json::from_value(bp.clone())
                .map_err(|e| OzoneError::StorageError(format!("Failed to parse blueprint: {}", e)))?;

            let container = self.create_blueprint_container(&metadata, blueprints_root_id);

            // Store in ZSEI
            let container_id = zsei.store_container(container).await?;

            // Update cache
            {
                let mut cache = self.cache.write().await;
                cache.insert(metadata.blueprint_id, metadata);
            }

            tracing::debug!("Registered blueprint {} as ZSEI container {}",
                container_id, metadata.name);
        }

        tracing::info!("Registered {} blueprints in ZSEI", blueprints.len());
        Ok(())
    }

    /// Create a ZSEI container for a single blueprint
    fn create_blueprint_container(
        &self,
        metadata: &BlueprintMetadata,
        parent_id: ContainerID,
    ) -> Container {
        Container {
            global_state: GlobalState {
                container_id: self.generate_container_id(metadata.blueprint_id),
                parent_id,
                child_ids: vec![],
                child_count: 0,
                version: 1,
            },
            local_state: LocalState {
                metadata: {
                    let mut m = std::collections::HashMap::new();
                    m.insert("container_type".to_string(), serde_json::json!("Blueprint"));
                    m.insert("name".to_string(), serde_json::json!(&metadata.name));
                    m.insert("blueprint_id".to_string(), serde_json::json!(metadata.blueprint_id));
                    m.insert("signature_hash".to_string(), serde_json::json!(&metadata.signature_hash));
                    m.insert("file".to_string(), serde_json::json!(&metadata.file));
                    if let Some(desc) = &metadata.description {
                        m.insert("description".to_string(), serde_json::json!(desc));
                    }
                    m
                },
                context: crate::types::container::Context {
                    keywords: metadata.keywords.clone(),
                    topics: vec![],
                    categories: vec!["blueprint".to_string()],
                    relationships: vec![],           // can be populated later
                    learned_associations: vec![],
                    embedding: None,
                },
                storage: crate::types::container::StorageInfo {
                    object_store_path: Some(format!("blueprints/{}", metadata.file)),
                    ..Default::default()
                },
                hints: crate::types::container::Hints {
                    access_frequency: 0,
                    hotness_score: 0.0,
                    last_accessed: 0,
                    ..Default::default()
                },
                integrity: crate::types::container::IntegrityRecord {
                    content_hash: [0u8; 32],  // TODO: compute real hash
                    integrity_score: 1.0,
                    ..Default::default()
                },
                ..Default::default()
            },
        }
    }

    /// Find or create the /Modality/Blueprints root container
    async fn find_or_create_blueprints_root(&self, zsei: &ZSEI) -> OzoneResult<ContainerID> {
        // In a real system you would query by materialized_path or type
        // For simplicity, we assume a known ID or create if missing
        // You can enhance this with a proper lookup

        let root_id = 2000; // Arbitrary offset for blueprint root

        if zsei.get_container(root_id).await?.is_none() {
            let root_container = Container {
                global_state: GlobalState {
                    container_id: root_id,
                    parent_id: 0, // under root or modality root
                    child_ids: vec![],
                    child_count: 0,
                    version: 1,
                },
                local_state: LocalState {
                    metadata: {
                        let mut m = std::collections::HashMap::new();
                        m.insert("container_type".to_string(), serde_json::json!("Category"));
                        m.insert("name".to_string(), serde_json::json!("Blueprints"));
                        m.insert("modality".to_string(), serde_json::json!("blueprint"));
                        m
                    },
                    context: crate::types::container::Context {
                        keywords: vec!["blueprint".to_string()],
                        ..Default::default()
                    },
                    ..Default::default()
                },
            };
            zsei.store_container(root_container).await?;
        }

        Ok(root_id)
    }

    fn generate_container_id(&self, blueprint_id: u64) -> ContainerID {
        30000 + blueprint_id   // offset to avoid collision with other containers
    }

    /// Get blueprint metadata by ID (fast cache hit)
    pub async fn get_blueprint(&self, blueprint_id: u64) -> Option<BlueprintMetadata> {
        let cache = self.cache.read().await;
        cache.get(&blueprint_id).cloned()
    }

    /// Search blueprints by keyword (uses ZSEI traversal in production)
    pub async fn search_by_keyword(&self, keyword: &str) -> Vec<BlueprintMetadata> {
        let cache = self.cache.read().await;
        cache.values()
            .filter(|bp| {
                bp.keywords.iter().any(|k| k.to_lowercase().contains(&keyword.to_lowercase())) ||
                bp.name.to_lowercase().contains(&keyword.to_lowercase())
            })
            .cloned()
            .collect()
    }

    /// Link a blueprint to a methodology or pipeline (adds relationship in ZSEI)
    pub async fn link_to(&self, blueprint_id: u64, target_container_id: ContainerID, relationship_type: &str) -> OzoneResult<()> {
        let zsei = self.zsei.write().await;
        // In real implementation: load blueprint container, add relationship, store back
        // For now, placeholder
        tracing::info!("Linked blueprint {} to container {} with type {}",
            blueprint_id, target_container_id, relationship_type);
        Ok(())
    }
}
```

