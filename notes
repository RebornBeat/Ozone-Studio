// After copy_methodologies() and copy_pipelines()

// Register methodologies as ZSEI containers
let methodology_store = MethodologyStore::new(
    runtime.zsei.clone(),
    self.data_dir.join("methodologies/index.json")
);
methodology_store.register_all_methodologies().await?;
```

Do the same for blueprints and pipelines if you want them as containers too.

