### 2.1 Text Modality Actions

```rust
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(tag = "action")]
pub enum TextModalityAction {
    // === ANALYSIS ===
    Analyze {
        text: TextDataSource,
        depth: AnalysisDepth,
        extract_grammar: bool,
        detect_modalities: bool,
        identify_true_text: bool,
    },

    // === CHUNKING ===
    ChunkWithOverlap {
        text: String,
        target_chunk_tokens: u32,
        overlap_tokens: u32,
        use_llm_resolution: bool,
    },

    // === GRAMMAR ===
    ExtractGrammarRelationships {
        text: String,
        sentence_mode: SentenceMode,
    },

    // === MODALITY DETECTION ===
    DetectModalities {
        text: String,
        include_true_text: bool,
        dynamic_modality_list: bool,
    },

    // === GRAPH ===
    CreateGraph {
        analysis: TextAnalysisResult,
        project_id: u64,
        workspace_id: u64,
        include_chunk_refs: bool,
    },

    // === CHUNK GRAPHS ===
    CreateChunkGraph {
        chunk: ProcessedChunk,
        root_graph_id: u64,
    },

    // === CROSS-MODALITY ===
    BuildCrossModalRefs {
        text_graph_id: u64,
        target_modality_graphs: Vec<u64>,
    },

    // === FILE ATTACHMENTS ===
    ProcessAttachedFile {
        file_path: String,
        file_content: Option<String>,
        is_supplementary: bool,
    },
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub enum TextDataSource {
    RawText(String),
    File { path: String, format: String },
    Url { url: String },
}

#[derive(Debug, Clone, Serialize, Deserialize, Default)]
pub enum AnalysisDepth {
    #[default]
    Quick,      // Keywords + basic entities
    Standard,   // + Grammar + modality detection
    Deep,       // + Cross-sentence discourse
}

#[derive(Debug, Clone, Serialize, Deserialize, Default)]
pub enum SentenceMode {
    #[default]
    Single,     // Per-sentence analysis
    Paragraph,  // Paragraph-level context
    Document,   // Full document context
}
