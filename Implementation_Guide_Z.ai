### 2.5 Text Modality Implementation

```rust
impl TextModalityPipeline {
    /// Main execute function
    pub async fn execute(input: TextModalityAction) -> Result<TextModalityOutput, String> {
        match input {
            TextModalityAction::Analyze { text, depth, extract_grammar, detect_modalities, identify_true_text } => {
                Self::analyze(text, depth, extract_grammar, detect_modalities, identify_true_text).await
            }

            TextModalityAction::ChunkWithOverlap { text, target_chunk_tokens, overlap_tokens, use_llm_resolution } => {
                Self::chunk_with_overlap(text, target_chunk_tokens, overlap_tokens, use_llm_resolution).await
            }

            TextModalityAction::ExtractGrammarRelationships { text, sentence_mode } => {
                Self::extract_grammar_relationships(text, sentence_mode).await
            }

            TextModalityAction::DetectModalities { text, include_true_text, dynamic_modality_list } => {
                Self::detect_modalities(text, include_true_text, dynamic_modality_list).await
            }

            TextModalityAction::CreateGraph { analysis, project_id, workspace_id, include_chunk_refs } => {
                Self::create_graph(analysis, project_id, workspace_id, include_chunk_refs).await
            }

            TextModalityAction::CreateChunkGraph { chunk, root_graph_id } => {
                Self::create_chunk_graph(chunk, root_graph_id).await
            }

            TextModalityAction::BuildCrossModalRefs { text_graph_id, target_modality_graphs } => {
                Self::build_cross_modal_refs(text_graph_id, target_modality_graphs).await
            }

            TextModalityAction::ProcessAttachedFile { file_path, file_content, is_supplementary } => {
                Self::process_attached_file(file_path, file_content, is_supplementary).await
            }
        }
    }

    // === CHUNKING WITH LLM OVERLAP RESOLUTION ===

    async fn chunk_with_overlap(
        text: String,
        target_chunk_tokens: u32,
        overlap_tokens: u32,
        use_llm_resolution: bool,
    ) -> Result<Vec<ProcessedChunk>, String> {
        // Step 1: Initial chunk split by token count
        let raw_chunks = Self::split_by_tokens(&text, target_chunk_tokens)?;

        // Step 2: Resolve overlaps between consecutive chunks
        let mut processed_chunks = Vec::new();

        for i in 0..raw_chunks.len() {
            let current = &raw_chunks[i];
            let next = if i + 1 < raw_chunks.len() {
                Some(&raw_chunks[i + 1])
            } else {
                None
            };

            let overlap_resolution = if let Some(next_chunk) = next {
                if use_llm_resolution {
                    Self::resolve_overlap_llm(current, next_chunk, overlap_tokens).await?
                } else {
                    Self::resolve_overlap_rule_based(current, next_chunk, overlap_tokens)
                }
            } else {
                None
            };

            // Apply resolution
            let resolved_text = if let Some(ref resolution) = overlap_resolution {
                if resolution.has_overlap {
                    current[..resolution.current_keep_end].to_string()
                } else {
                    current.clone()
                }
            } else {
                current.clone()
            };

            processed_chunks.push(ProcessedChunk {
                chunk_index: i as u32,
                text: resolved_text,
                start_char: 0, // Will be calculated
                end_char: 0,
                token_count: Self::count_tokens(&resolved_text),
                overlap_resolved: overlap_resolution.is_some(),
                overlap_with_previous: if i > 0 { processed_chunks.get(i - 1).and_then(|c| c.overlap_with_next.clone()) } else { None },
                overlap_with_next: overlap_resolution,
                keywords: Vec::new(),
                topics: Vec::new(),
                entities: Vec::new(),
                grammar_relationships: Vec::new(),
                detected_modalities: Vec::new(),
                true_text: true,
                chunk_graph_id: None,
                provenance: EdgeProvenance::DerivedFromPrompt,
                source_prompt_id: None,
            });
        }

        // Step 3: Calculate character positions
        let mut char_pos = 0;
        for chunk in &mut processed_chunks {
            chunk.start_char = char_pos;
            chunk.end_char = char_pos + chunk.text.len();
            char_pos = chunk.end_char;
        }

        Ok(processed_chunks)
    }

    async fn resolve_overlap_llm(
        current: &str,
        next: &str,
        overlap_tokens: u32,
    ) -> Result<OverlapResolution, String> {
        let current_tail = current.chars().rev().take(overlap_tokens as usize * 4).collect::<String>();
        let next_head = next.chars().take(overlap_tokens as usize * 4).collect::<String>();

        let prompt = format!(r#"
You are analyzing an overlapping region between two text chunks.

CURRENT CHUNK END (last ~{} tokens):
"...{}"

NEXT CHUNK START (first ~{} tokens):
"{}..."

Determine if there is duplicated content and where the clean boundary should be.

Return ONLY valid JSON:
{{
  "has_overlap": true/false,
  "overlap_type": "sentence_cutoff|paragraph_cutoff|word_cutoff|none",
  "current_keep_end_offset": <character offset from end of current where to cut>,
  "next_start_offset": <character offset from start of next where to begin>,
  "duplicate_belongs_in": "current|next|neither",
  "reasoning": "brief explanation"
}}"#, overlap_tokens, current_tail, overlap_tokens, next_head);

        let input = serde_json::json!({
            "prompt": prompt,
            "max_tokens": 200,
            "temperature": 0.1,
        });

        let result = Self::call_llm(input).await?;
        let parsed: OverlapResolutionLLM = Self::parse_json_response(&result)?;

        Ok(OverlapResolution {
            has_overlap: parsed.has_overlap,
            overlap_type: match parsed.overlap_type.as_str() {
                "sentence_cutoff" => OverlapType::SentenceCutoff,
                "paragraph_cutoff" => OverlapType::ParagraphCutoff,
                "word_cutoff" => OverlapType::WordCutoff,
                _ => OverlapType::None,
            },
            current_keep_end: current.len().saturating_sub(parsed.current_keep_end_offset),
            next_start_offset: parsed.next_start_offset,
            duplicate_belongs_in: match parsed.duplicate_belongs_in.as_str() {
                "current" => DuplicateOwner::CurrentChunk,
                "next" => DuplicateOwner::NextChunk,
                _ => DuplicateOwner::Neither,
            },
            resolution_method: ResolutionMethod::LLMZeroShot,
        })
    }

    // === MODALITY DETECTION ===

    async fn detect_modalities(
        text: &str,
        include_true_text: bool,
        dynamic_modality_list: bool,
    ) -> Result<Vec<ModalitySpan>, String> {
        // Get available modalities dynamically
        let available_modalities = if dynamic_modality_list {
            Self::get_registered_modalities().await
        } else {
            vec!["code", "math", "chemistry", "dna", "image", "audio", "video", "3d", "eeg"].into_iter().map(String::from).collect()
        };

        let modality_list = available_modalities.join(", ");

        let prompt = format!(r#"
Identify all modality content embedded in or referenced by this text.

Available modalities: {}

Also identify:
- "true_text" for content that is genuinely text modality (prose, descriptions, explanations)
- "unknown" for content that doesn't fit any available modality

Text:
{}

Return ONLY valid JSON array:
[{{
  "modality": "modality_name",
  "start_char": 0,
  "end_char": 100,
  "intent_reference": "how the text references or describes this modality",
  "source_file": null or "filename if from attached file"
}}]"#, modality_list, &text[..text.len().min(6000)]);

        let input = serde_json::json!({
            "prompt": prompt,
            "max_tokens": 1000,
            "temperature": 0.1,
        });

        let result = Self::call_llm(input).await?;
        let detections: Vec<ModalitySpanRaw> = Self::parse_json_array_response(&result)?;

        let mut spans = Vec::new();
        for d in detections {
            spans.push(ModalitySpan {
                modality: d.modality,
                start_char: d.start_char,
                end_char: d.end_char,
                referenced_from_chunks: Vec::new(),
                intent_reference: d.intent_reference,
                source_file: d.source_file,
            });
        }

        // 5x consecutive validation loop
        let mut stable_count = 0;
        let mut current_spans = spans.clone();

        for _ in 0..20 {
            let new_spans = Self::detect_modalities_pass(text, &available_modalities, &current_spans).await?;

            let new_findings = Self::find_new_spans(&current_spans, &new_spans);

            if new_findings.is_empty() {
                stable_count += 1;
                if stable_count >= 5 {
                    break;
                }
            } else {
                stable_count = 0;
                current_spans.extend(new_findings);
            }
        }

        Ok(current_spans)
    }

    // === GRAMMAR RELATIONSHIP EXTRACTION ===

    async fn extract_grammar_relationships(
        text: &str,
        sentence_mode: SentenceMode,
    ) -> Result<Vec<GrammarRelationship>, String> {
        let sentences = Self::split_sentences(text);
        let mut relationships = Vec::new();

        for (idx, sentence) in sentences.iter().enumerate() {
            let rels = Self::analyze_sentence_grammar(sentence, idx, &sentence_mode).await?;
            relationships.extend(rels);
        }

        // 5x consecutive validation
        let mut stable_count = 0;
        let mut current_rels = relationships.clone();

        for _ in 0..15 {
            let new_rels = Self::find_new_grammar_rels(text, &current_rels).await?;

            if new_rels.is_empty() {
                stable_count += 1;
                if stable_count >= 5 {
                    break;
                }
            } else {
                stable_count = 0;
                current_rels.extend(new_rels);
            }
        }

        Ok(current_rels)
    }

    async fn analyze_sentence_grammar(
        sentence: &str,
        sentence_index: usize,
        mode: &SentenceMode,
    ) -> Result<Vec<GrammarRelationship>, String> {
        let prompt = format!(r#"
Analyze this sentence for grammatical relationships.

Sentence: "{}"

Identify:
1. Subject (who/what performs the action)
2. Verb (the action or state)
3. Verb type: "action" (run, create), "linking" (is, seems), or "helping" (has, will)
4. Object (who/what receives the action, if any)
5. Tense: past, present, or future
6. Negation: is the action negated?

Then identify all semantic relationships between entities in the sentence:
- Performs: subject performs action on object
- Affects: one entity affects another
- Implies: one thing implies another
- Causes: causal relationship
- Enables: enables another action
- Prevents: prevents another action
- TemporalPrecedes: happens before
- PartOf: part-whole relationship
- SimilarTo: similarity relationship

Return ONLY valid JSON:
{{
  "subject": "...",
  "verb": "...",
  "verb_type": "action|linking|helping",
  "object": "..." or null,
  "tense": "past|present|future",
  "negated": false,
  "relationships": [
    {{
      "from": "entity name",
      "to": "entity name",
      "edge_type": "Performs|Affects|Implies|Causes|Enables|Prevents|TemporalPrecedes|PartOf|SimilarTo",
      "tense": "past|present|future",
      "negated": false
    }}
  ]
}}"#, sentence);

        let input = serde_json::json!({
            "prompt": prompt,
            "max_tokens": 500,
            "temperature": 0.1,
        });

        let result = Self::call_llm(input).await?;
        let parsed: GrammarAnalysisRaw = Self::parse_json_response(&result)?;

        let mut rels = Vec::new();
        for r in parsed.relationships {
            rels.push(GrammarRelationship {
                from_text: r.from,
                to_text: r.to,
                edge_type: Self::parse_edge_type(&r.edge_type),
                source_sentence: sentence.to_string(),
                sentence_index,
                tense: Some(r.tense),
                negated: r.negated,
                verb: parsed.verb.clone(),
                verb_type: Self::parse_verb_type(&parsed.verb_type),
                subject: parsed.subject.clone(),
                object: parsed.object.clone(),
                provenance: EdgeProvenance::DerivedFromPrompt,
            });
        }

        Ok(rels)
    }

    // === PROCESS ATTACHED FILES ===

    async fn process_attached_file(
        file_path: String,
        file_content: Option<String>,
        is_supplementary: bool,
    ) -> Result<AttachedFileInfo, String> {
        let extension = std::path::Path::new(&file_path)
            .extension()
            .and_then(|e| e.to_str())
            .unwrap_or("")
            .to_lowercase();

        // Map extension to modality
        let modality = Self::extension_to_modality(&extension);

        // Read content if not provided
        let content = file_content.unwrap_or_else(|| {
            std::fs::read_to_string(&file_path).unwrap_or_default()
        });

        // Infer intent via LLM
        let intent = if !is_supplementary {
            Self::infer_file_intent(&content, &modality).await?
        } else {
            None
        };

        Ok(AttachedFileInfo {
            path: file_path,
            modality,
            is_supplementary,
            inferred_intent: intent,
            span_start: 0,
            span_end: 0,
        })
    }

    fn extension_to_modality(ext: &str) -> String {
        match ext {
            "rs" | "py" | "js" | "ts" | "java" | "cpp" | "c" | "go" | "rb" | "php" => "code".to_string(),
            "json" | "yaml" | "yml" | "toml" | "xml" => "code".to_string(),
            "png" | "jpg" | "jpeg" | "gif" | "bmp" | "tiff" | "webp" => "image".to_string(),
            "mp3" | "wav" | "ogg" | "flac" | "aac" | "m4a" => "audio".to_string(),
            "mp4" | "avi" | "mkv" | "mov" | "webm" | "flv" => "video".to_string(),
            "blend" | "fbx" | "obj" | "gltf" | "glb" | "dae" | "stl" | "ply" => "3d".to_string(),
            "pdb" | "mol" | "sdf" | "cif" => "chemistry".to_string(),
            "fasta" | "fastq" | "gb" | "gff" | "vcf" | "bam" | "sam" => "dna".to_string(),
            "edf" | "bdf" | "gdf" | "vhdr" | "vmrk" | "eeg" => "eeg".to_string(),
            "tex" | "sty" | "cls" => "math".to_string(),
            "pdf" | "doc" | "docx" | "txt" | "md" | "rst" | "html" | "htm" => "text".to_string(),
            _ => "unknown".to_string(),
        }
    }

    // === CREATE GRAPH ===

    async fn create_graph(
        analysis: TextAnalysisResult,
        project_id: u64,
        workspace_id: u64,
        include_chunk_refs: bool,
    ) -> Result<TextGraph, String> {
        let graph_id = Self::generate_graph_id();
        let now = chrono::Utc::now().to_rfc3339();

        // Create root node
        let root_id = 1u64;
        let root = TextRootNode {
            node_id: root_id,
            source_text_hash: Self::hash_text(&analysis.text),
            total_characters: analysis.text.len(),
            total_chunks: analysis.chunks.len(),
            detected_modalities: analysis.detected_modalities.clone(),
            true_text_spans: analysis.true_text_spans.clone(),
            attached_files: analysis.attached_files.clone(),
            file_modality_mappings: analysis.attached_files.iter()
                .map(|f| (f.path.clone(), f.modality.clone()))
                .collect(),
            provenance: EdgeProvenance::DerivedFromPrompt,
            source_prompt_id: None,
            document_nodes: Vec::new(),
            chunk_refs: Vec::new(),
        };

        let mut nodes = Vec::new();
        let mut edges = Vec::new();
        let mut node_counter = 2u64; // Start after root

        nodes.push(TextNode {
            core: NodeCore {
                node_id: root_id,
                node_type: "Root".to_string(),
                label: "Text Document".to_string(),
                content: analysis.text.chars().take(200).collect(),
                time_range: None,
                spatial_position: None,
                provisional: false,
                provisional_status: ProvisionalStatus::Finalized,
                provenance: EdgeProvenance::DerivedFromPrompt,
                source_chunk_id: None,
                source_file_id: None,
                created_by_step: None,
                updated_by_step: None,
                version: 1,
                version_notes: Vec::new(),
                materialized_path: Some(format!("/TextGraph/{}/root", graph_id)),
                keywords: analysis.keywords.iter().take(20).map(|k| k.keyword.clone()).collect(),
                embedding_hint: None,
                hotness_score: 1.0,
                cross_modal_refs: Vec::new(),
            },
            node_type: TextNodeType::Root,
            text_content: analysis.text.chars().take(500).collect(),
            character_range: (0, analysis.text.len()),
            chunk_index: None,
        });

        // Create sentence nodes
        for (idx, sentence) in analysis.sentences.iter().enumerate() {
            let node_id = node_counter;
            node_counter += 1;

            nodes.push(TextNode {
                core: NodeCore {
                    node_id,
                    node_type: "Sentence".to_string(),
                    label: format!("Sentence {}", idx + 1),
                    content: sentence.text.clone(),
                    time_range: None,
                    spatial_position: None,
                    provisional: false,
                    provisional_status: ProvisionalStatus::Finalized,
                    provenance: EdgeProvenance::DerivedFromPrompt,
                    source_chunk_id: None,
                    source_file_id: None,
                    created_by_step: None,
                    updated_by_step: None,
                    version: 1,
                    version_notes: Vec::new(),
                    materialized_path: Some(format!("/TextGraph/{}/sentence/{}", graph_id, idx)),
                    keywords: Vec::new(),
                    embedding_hint: None,
                    hotness_score: 0.8,
                    cross_modal_refs: Vec::new(),
                },
                node_type: TextNodeType::Sentence,
                text_content: sentence.text.clone(),
                character_range: (sentence.start_char, sentence.end_char),
                chunk_index: None,
            });

            // Add edge from root to sentence
            edges.push(TextEdge {
                core: EdgeCore {
                    edge_id: edges.len() as u64 + 1,
                    from_node: root_id,
                    to_node: node_id,
                    edge_type: EdgeType::Contains,
                    weight: 1.0,
                    provenance: EdgeProvenance::DerivedFromPrompt,
                    created_by_step: None,
                    version: 1,
                    is_cross_modal: false,
                    cross_modal_index_id: None,
                    properties: HashMap::new(),
                },
                grammar_info: None,
            });
        }

        // Create grammar edges
        for rel in &analysis.grammar_relationships {
            // Find nodes for from and to text
            let from_node = nodes.iter().find(|n| {
                n.text_content.contains(&rel.from_text)
            });
            let to_node = nodes.iter().find(|n| {
                n.text_content.contains(&rel.to_text)
            });

            if let (Some(from), Some(to)) = (from_node, to_node) {
                edges.push(TextEdge {
                    core: EdgeCore {
                        edge_id: edges.len() as u64 + 1,
                        from_node: from.core.node_id,
                        to_node: to.core.node_id,
                        edge_type: rel.edge_type.clone(),
                        weight: 1.0,
                        provenance: rel.provenance.clone(),
                        created_by_step: None,
                        version: 1,
                        is_cross_modal: false,
                        cross_modal_index_id: None,
                        properties: HashMap::new(),
                    },
                    grammar_info: Some(GrammarEdgeInfo {
                        verb: rel.verb.clone(),
                        verb_type: rel.verb_type.clone(),
                        tense: rel.tense.clone().unwrap_or_default(),
                        negated: rel.negated,
                        source_sentence: rel.source_sentence.clone(),
                    }),
                });
            }
        }

        // Create modality reference nodes
        for mod_span in &analysis.detected_modalities {
            if mod_span.modality != "true_text" && mod_span.modality != "unknown" {
                let node_id = node_counter;
                node_counter += 1;

                nodes.push(TextNode {
                    core: NodeCore {
                        node_id,
                        node_type: "ModalityReference".to_string(),
                        label: format!("[{}]", mod_span.modality),
                        content: format!("{} reference", mod_span.modality),
                        time_range: None,
                        spatial_position: None,
                        provisional: false,
                        provisional_status: ProvisionalStatus::Finalized,
                        provenance: EdgeProvenance::DerivedFromPrompt,
                        source_chunk_id: None,
                        source_file_id: None,
                        created_by_step: None,
                        updated_by_step: None,
                        version: 1,
                        version_notes: Vec::new(),
                        materialized_path: Some(format!("/TextGraph/{}/modality/{}", graph_id, mod_span.modality)),
                        keywords: vec![mod_span.modality.clone()],
                        embedding_hint: None,
                        hotness_score: 0.9,
                        cross_modal_refs: vec![],
                    },
                    node_type: TextNodeType::ModalityReference,
                    text_content: format!("[{} content at {}-{}]", mod_span.modality, mod_span.start_char, mod_span.end_char),
                    character_range: (mod_span.start_char, mod_span.end_char),
                    chunk_index: None,
                });

                edges.push(TextEdge {
                    core: EdgeCore {
                        edge_id: edges.len() as u64 + 1,
                        from_node: root_id,
                        to_node: node_id,
                        edge_type: EdgeType::ReferencesModality,
                        weight: 1.0,
                        provenance: EdgeProvenance::DerivedFromPrompt,
                        created_by_step: None,
                        version: 1,
                        is_cross_modal: true,
                        cross_modal_index_id: None,
                        properties: {
                            let mut p = HashMap::new();
                            p.insert("target_modality".to_string(), serde_json::json!(mod_span.modality));
                            p
                        },
                    },
                    grammar_info: None,
                });
            }
        }

        Ok(TextGraph {
            graph_id,
            project_id,
            workspace_id,
            root,
            nodes,
            edges,
            state: GraphState {
                graph_id,
                modality: "text".to_string(),
                project_id,
                current_state: GraphStateType::SemanticEnriched,
                state_history: vec![StateTransition {
                    from_state: GraphStateType::Created,
                    to_state: GraphStateType::SemanticEnriched,
                    timestamp: now.clone(),
                    trigger: StateTransitionTrigger::SemanticPass,
                    step_index: None,
                    nodes_added: nodes.len(),
                    edges_added: edges.len(),
                }],
                structural_nodes: nodes.len(),
                semantic_nodes: edges.iter().filter(|e| e.core.is_cross_modal).count(),
                cross_modal_nodes: nodes.iter().filter(|n| n.node_type == TextNodeType::ModalityReference).count(),
                structural_edges: edges.iter().filter(|e| !e.core.is_cross_modal).count(),
                semantic_edges: edges.iter().filter(|e| !e.core.is_cross_modal && e.grammar_info.is_some()).count(),
                cross_modal_edges: edges.iter().filter(|e| e.core.is_cross_modal).count(),
                provisional_nodes: 0,
                last_semantic_pass: 1,
                last_cross_ref_pass: 0,
                consecutive_stable_passes: 0,
                version: 1,
                last_updated: now.clone(),
                last_updated_by_step: None,
                source_prompt_id: None,
                source_chunk_ids: Vec::new(),
                source_file_ids: Vec::new(),
            },
            chunk_graphs: Vec::new(),
            cross_modal_index_id: None,
        })
    }
}
```

