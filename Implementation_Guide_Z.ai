### 26.2 Main Orchestration Flow

```rust
impl Orchestrator {
    pub async fn orchestrate(request: OrchestrationRequest) -> Result<OrchestrationResult, String> {
        let mut state = OrchestrationState::new(request);

        // PHASE 1: Prompt Normalization
        state.transition_to(Phase::PromptNormalization);
        self.normalize_prompt(&mut state).await?;

        // PHASE 2: Modality Detection
        state.transition_to(Phase::ModalityDetection);
        self.detect_all_modalities(&mut state).await?;

        // PHASE 3: Initial Graph Creation
        state.transition_to(Phase::InitialGraphCreation);
        self.create_initial_graphs(&mut state).await?;

        // PHASE 4: AMT Building
        state.transition_to(Phase::AMTBuilding);
        self.build_amt_layer_by_layer(&mut state).await?;

        // PHASE 5: Blueprint Creation
        state.transition_to(Phase::BlueprintCreation);
        self.create_blueprint(&mut state).await?;

        // PHASE 6: Step Execution
        state.transition_to(Phase::StepExecution);
        self.execute_steps(&mut state).await?;

        state.transition_to(Phase::Completed);

        Ok(state.to_result())
    }

    // === PHASE 1: PROMPT NORMALIZATION ===

    async fn normalize_prompt(&self, state: &mut OrchestrationState) -> Result<(), String> {
        // Step 1: Clean the prompt
        state.cleaned_prompt = self.clean_prompt(&state.request.prompt);

        // Step 2: Process attached files first
        for file in &state.request.attached_files {
            let file_info = self.process_attached_file(file).await?;
            state.attached_files.push(file_info);
        }

        // Step 3: Chunk with LLM overlap resolution
        let chunks = self.chunk_with_llm_overlap(&state.cleaned_prompt).await?;
        state.raw_chunks = chunks.clone();

        // Step 4: Process each chunk (5x consecutive for each extraction)
        for (idx, chunk) in chunks.iter().enumerate() {
            let processed = self.process_chunk(chunk, idx as u32).await?;
            state.processed_chunks.push(processed);
        }

        Ok(())
    }

    async fn process_chunk(&self, chunk: &RawChunk, index: u32) -> Result<ProcessedChunk, String> {
        // Keywords: 5x consecutive
        let keywords = self.extract_keywords_until_stable(&chunk.text).await;

        // Topics: 5x consecutive
        let topics = self.extract_topics_until_stable(&chunk.text).await;

        // Entities
        let entities = self.extract_entities(&chunk.text).await;

        // Grammar relationships
        let grammar = self.extract_grammar(&chunk.text).await;

        // Modalities in chunk: 5x consecutive
        let modalities = self.detect_modalities_until_stable(&chunk.text).await;

        Ok(ProcessedChunk {
            chunk_index: index,
            text: chunk.text.clone(),
            start_char: chunk.start_char,
            end_char: chunk.end_char,
            token_count: chunk.token_count,
            overlap_resolved: chunk.overlap_resolution.is_some(),
            overlap_with_previous: None,
            overlap_with_next: chunk.overlap_resolution.clone(),
            keywords,
            topics,
            entities,
            grammar_relationships: grammar,
            detected_modalities: modalities,
            true_text: true,
            chunk_graph_id: None,
            provenance: EdgeProvenance::DerivedFromPrompt,
            source_prompt_id: None,
        })
    }

    // === PHASE 2: MODALITY DETECTION ===

    async fn detect_all_modalities(&self, state: &mut OrchestrationState) -> Result<(), String> {
        // Aggregate modalities from all chunks
        let mut all_modalities: HashSet<String> = HashSet::new();

        for chunk in &state.processed_chunks {
            for mod_span in &chunk.detected_modalities {
                all_modalities.insert(mod_span.modality.clone());
            }
        }

        // Add modalities from attached files
        for file in &state.attached_files {
            all_modalities.insert(file.modality.clone());
        }

        // Always include text if we have content
        if !state.cleaned_prompt.is_empty() {
            all_modalities.insert("text".to_string());
        }

        state.detected_modalities = all_modalities.into_iter().collect();

        // Verify all modalities have handlers
        self.verify_modality_handlers(&state.detected_modalities).await?;

        Ok(())
    }

    async fn verify_modality_handlers(&self, modalities: &[String]) -> Result<(), String> {
        let registered = self.get_registered_modalities().await;

        for m in modalities {
            if m != "unknown" && !registered.contains(m) {
                // Flag for META clarification
                self.flag_unknown_modality(m).await?;
            }
        }

        Ok(())
    }

    // === PHASE 3: INITIAL GRAPH CREATION ===

    async fn create_initial_graphs(&self, state: &mut OrchestrationState) -> Result<(), String> {
        // Step 1: Create ALL modality graphs in parallel (structural)
        let mut graph_futures = Vec::new();

        for modality in &state.detected_modalities.clone() {
            graph_futures.push(self.create_modality_graph_structural(modality, state));
        }

        let graphs = futures::future::join_all(graph_futures).await;

        for (modality, graph_result) in state.detected_modalities.iter().zip(graphs) {
            if let Ok(graph_id) = graph_result {
                state.modality_graphs.insert(modality.clone(), graph_id);
            }
        }

        // Step 2: Semantic enrichment (TEXT first, then others)
        if let Some(text_graph_id) = state.modality_graphs.get("text").copied() {
            self.enrich_text_graph(text_graph_id, state).await?;
        }

        // Enrich other modalities (can be parallel after text)
        let other_modalities: Vec<_> = state.detected_modalities.iter()
            .filter(|m| *m != "text")
            .collect();

        for modality in other_modalities {
            if let Some(graph_id) = state.modality_graphs.get(modality).copied() {
                self.enrich_modality_graph(graph_id, modality, state).await?;
            }
        }

        // Step 3: Cross-modality linking (iterative 5x)
        self.build_cross_modal_refs(state).await?;

        Ok(())
    }

    async fn build_cross_modal_refs(&self, state: &mut OrchestrationState) -> Result<(), String> {
        let mut stable_count = 0;

        for _ in 0..20 {
            let new_refs = self.discover_cross_modal_refs(state).await?;

            if new_refs.is_empty() {
                stable_count += 1;
                if stable_count >= 5 {
                    break;
                }
            } else {
                stable_count = 0;
                self.register_cross_modal_refs(new_refs, state).await?;
            }
        }

        Ok(())
    }

    // === PHASE 4: AMT BUILDING (LAYER BY LAYER) ===

    async fn build_amt_layer_by_layer(&self, state: &mut OrchestrationState) -> Result<(), String> {
        let mut layer = 0;

        loop {
            layer += 1;
            state.amt_layer = layer;

            // Build this layer
            self.build_amt_layer(state, layer).await?;

            // Validate this layer (5x consecutive)
            let mut layer_stable = 0;

            for _ in 0..50 {
                let findings = self.validate_amt_layer(state, layer).await?;
                let method_gaps = self.check_methodology_gaps(state, layer).await?;

                if findings.is_empty() && method_gaps.is_empty() {
                    layer_stable += 1;
                    if layer_stable >= 5 {
                        break;
                    }
                } else {
                    layer_stable = 0;
                    self.expand_amt_layer(state, layer, findings, method_gaps).await?;
                }
            }

            // Check if more layers needed
            if !self.has_more_layers(state).await? {
                break;
            }
        }

        state.amt_stable = true;
        Ok(())
    }

    // === PHASE 5: BLUEPRINT CREATION ===

    async fn create_blueprint(&self, state: &mut OrchestrationState) -> Result<(), String> {
        // Order AMT into steps
        let steps = self.order_amt_into_steps(&state.amt).await?;

        // Identify required pipelines
        let pipelines = self.identify_pipelines(&steps).await?;

        // Create missing pipelines
        for req in &pipelines.missing {
            self.create_pipeline(req, state).await?;
        }

        // Create step states
        for (idx, step) in steps.iter().enumerate() {
            state.step_states.insert(idx as u32, StepState {
                step_index: idx as u32,
                status: StepStatus::Planned,
                current_stage: None,
                stages_completed: Vec::new(),
                stages_pending: step.stages.clone(),
                graph_ids_modified: Vec::new(),
                version: 1,
                version_notes: Vec::new(),
                waiting_on: step.dependencies.clone(),
                can_proceed: step.dependencies.is_empty(),
            });
        }

        state.blueprint_steps = steps;

        Ok(())
    }

    // === PHASE 6: STEP EXECUTION ===

    async fn execute_steps(&self, state: &mut OrchestrationState) -> Result<(), String> {
        loop {
            // Get ready steps
            let ready = self.get_ready_steps(state);

            if ready.is_empty() && self.all_steps_complete(state) {
                break;
            }

            // Execute each ready step
            for step_idx in ready {
                self.execute_step(step_idx, state).await?;
            }
        }

        Ok(())
    }

    async fn execute_step(&self, step_idx: u32, state: &mut OrchestrationState) -> Result<(), String> {
        let step = &state.blueprint_steps[step_idx as usize];

        // Update state to active
        state.step_states.get_mut(&step_idx).unwrap().status = StepStatus::Active;

        // Execute the step
        let result = self.run_step(step, state).await?;

        // HOOK: On step completion
        self.on_step_completion(step_idx, result, state).await?;

        Ok(())
    }

    async fn on_step_completion(
        &self,
        step_idx: u32,
        result: StepResult,
        state: &mut OrchestrationState,
    ) -> Result<(), String> {
        // Update step state
        let step_state = state.step_states.get_mut(&step_idx).unwrap();
        step_state.version += 1;
        step_state.version_notes.push(VersionNote {
            version: step_state.version,
            note: result.summary.clone(),
            step_index: Some(step_idx),
            timestamp: chrono::Utc::now().to_rfc3339(),
            change_type: ChangeType::Modified,
        });

        // Detect graph modifications
        let graph_updates = self.detect_graph_updates(&result, state).await;

        if !graph_updates.is_empty() {
            // Apply updates
            for update in &graph_updates {
                self.apply_graph_update(update, state).await?;
                step_state.graph_ids_modified.push(update.graph_id);
            }

            // Review AMT alignment
            let amt_expanded = self.review_amt_alignment(state).await?;

            if amt_expanded {
                // Create new steps for new branches
                let new_steps = self.synthesize_new_steps(state).await?;
                state.blueprint_steps.extend(new_steps);

                // Re-verify methodologies
                self.verify_methodologies(state).await?;

                // Re-verify pipelines
                self.verify_pipelines(state).await?;
            }

            // Update dependent steps
            self.propagate_updates(state, &graph_updates).await?;
        }

        // Mark step complete if all stages done
        if result.all_stages_complete {
            step_state.status = StepStatus::Completed;
        }

        Ok(())
    }
}
```

