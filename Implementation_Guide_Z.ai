## PART 27: TASK MANAGER

```rust
pub struct TaskManager {
    tasks: Arc<RwLock<HashMap<TaskID, Task>>>,
    steps: Arc<RwLock<HashMap<TaskID, Vec<TaskStep>>>>,
    progress: Arc<RwLock<HashMap<TaskID, TaskProgress>>>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Task {
    pub task_id: TaskID,
    pub blueprint_id: u64,
    pub status: TaskStatus,
    pub created_at: String,
    pub updated_at: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TaskStep {
    pub step_index: u32,
    pub pipeline_id: u64,
    pub pipeline_name: String,
    pub status: StepStatus,
    pub stages: Vec<StageInfo>,
    pub version: u32,
    pub version_notes: Vec<VersionNote>,
    pub graph_ids_modified: Vec<u64>,
    pub dependencies: Vec<u32>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct StageInfo {
    pub name: String,
    pub status: StageStatus,
    pub started_at: Option<String>,
    pub completed_at: Option<String>,
    pub output_preview: Option<String>,
}

impl TaskManager {
    pub async fn update_step(
        &self,
        task_id: TaskID,
        step_index: u32,
        status: &str,
        tokens_used: Option<u32>,
        output_preview: Option<String>,
        pipeline_name: String,
        version_note: Option<String>,
        graph_updates: Vec<String>,
    ) -> Result<(), String> {
        let mut steps = self.steps.write().await;
        let task_steps = steps.get_mut(&task_id).ok_or("Task not found")?;
        let step = task_steps.get_mut(step_index as usize).ok_or("Step not found")?;

        step.status = match status {
            "planned" => StepStatus::Planned,
            "active" => StepStatus::Active,
            "completed" => StepStatus::Completed,
            "failed" => StepStatus::Failed,
            _ => step.status.clone(),
        };

        if let Some(note) = version_note {
            step.version += 1;
            step.version_notes.push(VersionNote {
                version: step.version,
                note,
                step_index: Some(step_index),
                timestamp: chrono::Utc::now().to_rfc3339(),
            });
        }

        for graph_id in graph_updates {
            if !step.graph_ids_modified.contains(&graph_id.parse().unwrap()) {
                step.graph_ids_modified.push(graph_id.parse().unwrap());
            }
        }

        Ok(())
    }
}
```

