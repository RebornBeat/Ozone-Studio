module.exports = {
  meta: {
    title: 'Proof',
    icon: '∑',
    version: '0.4.0',
  },

  render: function(container, props, React, ReactDOM) {
    const { useState, useEffect, useRef } = React;
    const { executePipeline, getSharedState } = props;

    const STEP_TYPE_COLORS = {
      Given: '#2ecc71',
      Assumption: '#e67e22',
      Application: '#3498db',
      Deduction: '#9b59b6',
      Conclusion: '#e74c3c',
      InductionBase: '#1abc9c',
      InductionStep: '#27ae60',
      Contradiction: '#c0392b',
    };

    function ProofEngineUI() {
      const [graphData, setGraphData] = useState(null);
      const [selectedNode, setSelectedNode] = useState(null);
      const [viewMode, setViewMode] = useState('tree');    // tree | scope | assumptions | deps
      const [loading, setLoading] = useState(true);
      const [graphId, setGraphId] = useState(null);

      useEffect(() => {
        const state = getSharedState();
        const gId = state.activeGraphId || state.mathGraphId;
        if (gId) {
