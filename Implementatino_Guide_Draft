            viewMode === 'calls' && React.createElement('div', null,
              React.createElement('h5', null, 'Call Graph'),
              callEdges.length === 0
                ? React.createElement('p', { className: 'empty-note' }, 'No call edges (analysis depth may be Surface)')
                : callEdges.slice(0, 50).map((edge, i) => {
                    const from = allNodes.find(n => n.node_id === edge.from_node);
                    const to = allNodes.find(n => n.node_id === edge.to_node);
                    return React.createElement('div', { key: i, className: 'call-edge-item' },
                      React.createElement('span', { className: 'call-from' }, from?.name || `#${edge.from_node}`),
                      React.createElement('span', { className: 'call-arrow' }, '→'),
                      React.createElement('span', { className: 'call-to' }, to?.name || `#${edge.to_node}`)
                    );
                  })
            ),

            viewMode === 'patterns' && React.createElement('div', null,
              React.createElement('h5', null, 'Design Patterns'),
              patternEdges.length === 0
                ? React.createElement('p', { className: 'empty-note' }, 'No patterns detected')
                : patternEdges.map((edge, i) => {
                    const node = allNodes.find(n => n.node_id === edge.from_node);
                    return React.createElement('div', { key: i, className: 'pattern-item' },
                      React.createElement('span', {
                        className: 'pattern-badge',
                        style: { color: edge.edge_type === 'ImplementsPattern' ? '#2ecc71' : '#f1c40f' },
                      }, edge.edge_type === 'ImplementsPattern' ? '✦' : '◇'),
                      React.createElement('span', { className: 'pattern-node' }, node?.name || `#${edge.from_node}`),
                      React.createElement('span', { className: 'pattern-type' }, edge.properties?.pattern || edge.edge_type)
                    );
                  })
            ),

            viewMode === 'intent' && React.createElement('div', null,
              React.createElement('h5', null, 'Intent Relationships'),
              intentEdges.length === 0
                ? React.createElement('p', { className: 'empty-note' }, 'No intent edges — run Deep analysis')
                : intentEdges.map((edge, i) => {
                    const from = allNodes.find(n => n.node_id === edge.from_node);
                    const to = allNodes.find(n => n.node_id === edge.to_node);
                    return React.createElement('div', { key: i, className: 'intent-edge-item' },
                      React.createElement('span', { className: 'intent-label' }, '⚡'),
                      React.createElement('span', null, `${from?.name || '?'} solves ${to?.name || '?'}`),
                      edge.properties?.detail && React.createElement('p', { className: 'intent-detail' }, edge.properties.detail)
                    );
                  })
            ),

            viewMode === 'deps' && React.createElement('div', null,
              React.createElement('h5', null, 'Dependencies'),
              allEdges
                .filter(e => e.edge_type === 'DependsOn' || e.edge_type === 'Imports')
                .slice(0, 40)
                .map((edge, i) => {
                  const from = allNodes.find(n => n.node_id === edge.from_node);
                  const to = allNodes.find(n => n.node_id === edge.to_node);
                  return React.createElement('div', { key: i, className: 'dep-item' },
                    React.createElement('span', {
                      className: 'dep-type',
                      style: { color: EDGE_COLORS[edge.edge_type] || '#666' },
                    }, edge.edge_type),
                    React.createElement('span', { className: 'dep-name' }, to?.name || `#${edge.to_node}`)
                  );
                })
            )
          ),

          // CENTER: Simple graph visualization
          React.createElement('div', { className: 'code-graph-canvas' },
            React.createElement('svg', {
              ref: svgRef,
              viewBox: '0 0 600 400',
              style: { width: '100%', height: '100%' },
            },
              // Draw top-level nodes in a grid
              filteredNodes.slice(0, 20).map((node, i) => {
                const cols = 5;
                const col = i % cols;
                const row = Math.floor(i / cols);
                const x = 60 + col * 110;
                const y = 40 + row * 80;
                const color = NODE_COLORS[node.node_type] || '#666';
                return React.createElement('g', {
                  key: node.node_id,
                  transform: `translate(${x}, ${y})`,
                  onClick: () => setSelectedNode(node),
                  style: { cursor: 'pointer' },
                },
                  React.createElement('rect', {
                    x: -40, y: -15, width: 80, height: 30,
                    rx: 4, ry: 4,
                    fill: selectedNode?.node_id === node.node_id ? '#fff' : color,
                    stroke: color, strokeWidth: 1, opacity: 0.9,
                  }),
                  React.createElement('text', {
                    textAnchor: 'middle', dy: 4, fontSize: 9,
                    fill: selectedNode?.node_id === node.node_id ? '#333' : '#fff',
                    fontWeight: 'bold',
                  }, (node.name || '').slice(0, 12))
                );
              })
            )
          ),

          // RIGHT: Node detail
          React.createElement('div', { className: 'code-detail-panel' },
            selectedNode
              ? React.createElement('div', null,
                  React.createElement('h4', null, selectedNode.node_type),
                  React.createElement('div', { className: 'detail-field' },
                    React.createElement('label', null, 'Name'),
                    React.createElement('code', null, selectedNode.name)
                  ),
                  selectedNode.position && React.createElement('div', { className: 'detail-field' },
                    React.createElement('label', null, 'Location'),
                    React.createElement('span', null,
                      `${selectedNode.position.file_path || ''} L${selectedNode.position.start_line}–${selectedNode.position.end_line}`
                    )
                  ),
                  selectedNode.materialized_path && React.createElement('div', { className: 'detail-field' },
                    React.createElement('label', null, 'ZSEI Path'),
                    React.createElement('code', { className: 'small' }, selectedNode.materialized_path)
                  ),
                  React.createElement('div', { className: 'detail-field' },
                    React.createElement('label', null, 'Version'),
                    React.createElement('span', null, `v${selectedNode.version || 1}`)
                  ),
                  // Outgoing edges from this node
                  React.createElement('div', { className: 'detail-field' },
                    React.createElement('label', null, 'Edges'),
                    allEdges
                      .filter(e => e.from_node === selectedNode.node_id)
                      .slice(0, 8)
                      .map((edge, i) => {
                        const target = allNodes.find(n => n.node_id === edge.to_node);
                        return React.createElement('div', { key: i, className: 'edge-mini' },
                          React.createElement('span', {
                            className: 'edge-type-badge',
                            style: { color: EDGE_COLORS[edge.edge_type] || '#666' },
                          }, edge.edge_type),
                          React.createElement('span', null, target?.name || `#${edge.to_node}`)
                        );
                      })
                  ),
                  selectedNode.cross_modal_refs?.length > 0 && React.createElement('div', { className: 'detail-field' },
                    React.createElement('label', null, 'Cross-Modal'),
                    selectedNode.cross_modal_refs.map((ref, i) =>
                      React.createElement('div', { key: i, className: 'cross-ref-item' },
                        React.createElement('span', { className: 'ref-modality' }, ref.target_modality),
                        React.createElement('span', { className: 'ref-rel' }, ref.relationship)
                      )
                    )
                  )
                )
              : React.createElement('p', { className: 'empty-note' }, 'Select a node to inspect')
          )
        )
      );
    }

    const root = ReactDOM.createRoot(container);
    root.render(React.createElement(CodeIntelEngineUI));
    return () => root.unmount();
  },

  onActivate: function() {},
  onDeactivate: function() {},
};
