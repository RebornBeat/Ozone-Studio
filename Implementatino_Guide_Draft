// ── ENGINE TRAIT (Section L) ──────────────────────────────────────────────

/// Implemented by engine pipelines for polymorphic orchestrator dispatch.
/// All engine pipelines must be callable headlessly.
pub trait ModalityEngine: Send + Sync {
    fn modality_id(&self) -> u64;
    fn modality_name(&self) -> &str;

    /// AGI-first: process graph without rendering.
    fn process_headless(
        &self,
        graph_id: u64,
        operations: serde_json::Value,
    ) -> Result<serde_json::Value, String>;

    fn has_ui(&self) -> bool { false }
    fn ui_component_name(&self) -> Option<&str> { None }
    fn supports_simulation(&self) -> bool { false }
}
```

