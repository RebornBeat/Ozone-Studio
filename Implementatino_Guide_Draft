### 0.6.2 — `src/task/mod.rs`

**Replace** the entire `update_step` method with the 13-parameter version. **Remove** `update_step_full` entirely.

```rust
pub async fn update_step(
    &self,
    task_id: TaskID,
    step_index: u32,
    status: &str,
    tokens_used: Option<u32>,
    output_preview: Option<String>,
    execution_id: Option<String>,
    pipeline_name: &str,
    version_note: Option<String>,
    graph_ids_updated: Vec<String>,
    graph_ids_read: Vec<String>,
    stage_completed: Option<String>,
    stages_pending: Vec<String>,
    methodology_ids_applied: Vec<u64>,
) -> OzoneResult<()> {
    let mut tasks = self.tasks.write().await;
    if let Some(task) = tasks.get_mut(&task_id) {
        let step = task.steps.iter_mut().find(|s| s.step_index == step_index);
        if let Some(step) = step {
            step.status = status.to_string();
            if let Some(tok) = tokens_used { step.tokens_used = tok; }
            if let Some(preview) = output_preview { step.output_summary = Some(preview); }
            if !pipeline_name.is_empty() { step.pipeline_name = pipeline_name.to_string(); }
            if let Some(stage) = stage_completed {
                if !step.stages_completed.contains(&stage) {
                    step.stages_completed.push(stage);
                }
                step.current_stage = None;
            }
            step.stages_pending = stages_pending;
            if !graph_ids_updated.is_empty() { step.graph_ids_updated = graph_ids_updated; }
            if !graph_ids_read.is_empty() { step.graph_ids_read = graph_ids_read; }
            step.methodology_ids_applied = methodology_ids_applied;
            if let Some(note_text) = version_note {
                step.version += 1;
                step.version_notes.push(StepVersionNote {
                    version: step.version,
                    note: note_text,
                    timestamp: now(),
                    change_type: "Updated".to_string(),
                });
            }
            if status == "completed" || status == "failed" {
                step.completed_at = Some(now());
            }
        } else {
            task.steps.push(StoredTaskStep {
                step_index,
                pipeline_id: 0,
                pipeline_name: pipeline_name.to_string(),
                status: status.to_string(),
                started_at: Some(now()),
                completed_at: if status == "completed" || status == "failed" {
                    Some(now())
                } else { None },
                output_summary: output_preview,
                stages_completed: Vec::new(),
                stages_pending,
                current_stage: stage_completed,
                graph_ids_read,
                graph_ids_updated,
                tokens_used: tokens_used.unwrap_or(0),
                version: 1,
                version_notes: version_note.map(|n| vec![StepVersionNote {
                    version: 1, note: n, timestamp: now(),
                    change_type: "Created".to_string()
                }]).unwrap_or_default(),
                methodology_ids_applied,
            });
        }
        task.total_tokens = task.steps.iter().map(|s| s.tokens_used).sum();
    }
    Ok(())
}
```

